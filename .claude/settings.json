{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start-no-branches.sh",
            "timeout": 30,
            "statusMessage": "Enforcing no-feature-branches rule"
          }
        ]
      }
    ]
  }
}
