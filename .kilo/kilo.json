{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [
    ".kilo/instructions.md",
    ".kilo/rules/*.md"
  ],
  "snapshot": true,
  "default_agent": "plan",
  "model": "kilo/openai/gpt-5.5",
  "small_model": "kilo/openai/gpt-5.5",
  "agent": {
    "plan": {
      "model": "kilo/openai/gpt-5.5",
      "steps": 90,
      "options": {
        "reasoning_effort": "xhigh"
      }
    },
    "code": {
      "model": "kilo/openai/gpt-5.5",
      "steps": 90,
      "options": {
        "reasoning_effort": "xhigh"
      }
    },
    "debug": {
      "model": "kilo/openai/gpt-5.5",
      "steps": 90,
      "options": {
        "reasoning_effort": "high"
      }
    },
    "designer": {
      "mode": "primary",
      "description": "UI and visual mode for Next.js/Tailwind and chart-facing UX passes",
      "model": "kilo/openai/gpt-5.5",
      "steps": 90,
      "temperature": 0.4
    }
  }
}
