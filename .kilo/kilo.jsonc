{
  "$schema": "https://app.kilo.ai/config.json",
  "instructions": [
    ".kilo/instructions.md",
    ".kilo/rules/*.md"
  ],
  "disabled_providers": ["kilo"],
  "snapshot": true,
  "default_agent": "plan",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "id": "gpt-5.5",
          "name": "GPT 5.5 via OpenAI subscription auth",
          "reasoning": true,
          "temperature": false,
          "tool_call": true,
          "attachment": true,
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "prompt": "codex",
          "ai_sdk_provider": "openai",
          "cost": {
            "input": 0,
            "output": 0
          }
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "steps": 90,
      "options": {
        "reasoning_effort": "xhigh"
      }
    },
    "code": {
      "model": "openai/gpt-5.4",
      "steps": 90,
      "options": {
        "reasoning_effort": "xhigh"
      }
    },
    "ask": {
      "model": "openai/gpt-5.4",
      "steps": 90,
      "options": {
        "reasoning_effort": "xhigh"
      }
    },
    "debug": {
      "model": "openai/gpt-5.4",
      "steps": 90,
      "options": {
        "reasoning_effort": "high"
      }
    },
    "designer": {
      "mode": "primary",
      "description": "UI and visual mode for Next.js/Tailwind and chart-facing UX passes",
      "model": "openai/gpt-5.4",
      "steps": 90,
      "temperature": 0.4
    }
  }
}
