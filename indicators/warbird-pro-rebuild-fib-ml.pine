//=====================
// Helpers
//=====================
f_line_style(string styleName) =>
    styleName == "Dashed" ? line.style_dashed : styleName == "Dotted" ? line.style_dotted : line.style_solid

f_label_size(string sizeName) =>
    sizeName == "Tiny" ? size.tiny : sizeName == "Normal" ? size.normal : sizeName == "Large" ? size.large : size.small

f_table_pos(string p) =>
    p == "Top Left" ? position.top_left : p == "Bottom Right" ? position.bottom_right : p == "Bottom Left" ? position.bottom_left : position.top_right

calcMovingAverage(string type, float src, int length, int sigma) =>
    float result = na
    if type == "SMA"
        result := ta.sma(src, length)
    else if type == "EMA"
        result := ta.ema(src, length)
    else if type == "DEMA"
        float e1 = ta.ema(src, length)
        float e2 = ta.ema(e1, length)
        result := 2.0 * e1 - e2
    else if type == "TEMA"
        float e1 = ta.ema(src, length)
        float e2 = ta.ema(e1, length)
        float e3 = ta.ema(e2, length)
        result := 3.0 * (e1 - e2) + e3
    else if type == "WMA"
        float norm = 0.0
        float sum = 0.0
        for i = 0 to length - 1
            float weight = float(length - i)
            norm += weight
            sum += src[i] * weight
        result := norm > 0 ? sum / norm : src
    else if type == "VWMA"
        result := ta.vwma(src, length)
    else if type == "SMMA"
        result := ta.rma(src, length)
    else if type == "HMA"
        result := ta.hma(src, length)
    else if type == "LSMA"
        result := ta.linreg(src, length, 0)
    else
        result := ta.alma(src, length, 0.85, float(sigma))
    result

getMomentum(float source, int length) =>
    source - source[length]

getVolatility(float source, int length) =>
    ta.stdev(source, length)

getSlope(float source, int length) =>
    ta.linreg(source, length, 0) - ta.linreg(source, length, 1)

normalize(float source, int length) =>
    float maxVal = ta.highest(source, length)
    float minVal = ta.lowest(source, length)
    float valueRange = maxVal - minVal
    valueRange != 0 ? (source - minVal) / valueRange : 0.5

euclideanDistance(array<float> v1, array<float> v2) =>
    float sum = 0.0
    int n = math.min(array.size(v1), array.size(v2))
    for i = 0 to n - 1
        sum += math.pow(array.get(v1, i) - array.get(v2, i), 2.0)
    math.sqrt(sum)

//=====================
// Base metrics
//=====================
float atr14 = ta.atr(14)
float barRange = high - low
float bodySize = math.abs(close - open)
bool bullishCandle = close > open
bool bearishCandle = close < open
float upperWickSize = high - math.max(open, close)
float lowerWickSize = math.min(open, close) - low
float upperWickRatio = barRange > 0 ? upperWickSize / barRange : 0.0
float lowerWickRatio = barRange > 0 ? lowerWickSize / barRange : 0.0
float bodyRatio = barRange > 0 ? bodySize / barRange : 0.0

//=====================
// Candlestick patterns (winning set from Source A)
//=====================
bool longLowerShadow = lowerWickRatio >= 0.55 and upperWickRatio <= 0.25
bool dragonflyDoji = lowerWickRatio >= 0.60 and bodyRatio <= 0.15
bool risingWindow = low > high[1]

bool longUpperShadow = upperWickRatio >= 0.55 and lowerWickRatio <= 0.25
bool shootingStar = upperWickRatio >= 0.50 and bodyRatio <= 0.35 and bearishCandle
bool bearishEngulfing = bearishCandle and bullishCandle[1] and close < open[1] and open > close[1]
bool fallingWindow = high < low[1]

bool provenBullishPattern = longLowerShadow or dragonflyDoji or risingWindow
bool provenBearishPattern = longUpperShadow or shootingStar or bearishEngulfing or fallingWindow

//=====================
// ML RSI core
//=====================
float baseRsi = ta.rsi(close, rsiLength)
float smoothedRsi = calcMovingAverage(maType, baseRsi, smoothingLength, almaSigma)
float standardRsi = useSmoothing ? smoothedRsi : baseRsi

knnEnhancedRsi(float src) =>
    float enhancedRsi = src
    float knnDivergence = 0.0
    int effectiveK = 0
    float adaptiveOversoldMl = 30.0
    float adaptiveOverboughtMl = 70.0

    var array<float> overBoughtCandidates = array.new_float()
    var array<float> overSoldCandidates = array.new_float()
    array.clear(overBoughtCandidates)
    array.clear(overSoldCandidates)

    var array<float> currentPoint = array.new_float()
    array.clear(currentPoint)
    array.push(currentPoint, normalize(src, knnLookback))
    if featureCount >= 2
        array.push(currentPoint, normalize(getMomentum(src, 3), knnLookback))
    if featureCount >= 3
        array.push(currentPoint, normalize(getVolatility(src, 10), knnLookback))
    if featureCount >= 4
        array.push(currentPoint, normalize(getSlope(src, 5), knnLookback))
    if featureCount >= 5
        array.push(currentPoint, normalize(getMomentum(close, 5), knnLookback))

    var array<float> distances = array.new_float()
    var array<int> indices = array.new_int()
    array.clear(distances)
    array.clear(indices)

    for i = 6 to knnLookback
        if i < bar_index
            var array<float> historicalPoint = array.new_float()
            array.clear(historicalPoint)
            array.push(historicalPoint, normalize(src[i], knnLookback))
            if featureCount >= 2
                array.push(historicalPoint, normalize(getMomentum(src[i], 3), knnLookback))
            if featureCount >= 3
                array.push(historicalPoint, normalize(getVolatility(src[i], 10), knnLookback))
            if featureCount >= 4
                array.push(historicalPoint, normalize(getSlope(src[i], 5), knnLookback))
            if featureCount >= 5
                array.push(historicalPoint, normalize(getMomentum(close[i], 5), knnLookback))
            if array.size(currentPoint) == array.size(historicalPoint)
                float dist = euclideanDistance(currentPoint, historicalPoint)
                array.push(distances, dist)
                array.push(indices, i)

    if array.size(distances) > 1
        for i = 0 to array.size(distances) - 2
            for j = 0 to array.size(distances) - 2 - i
                if array.get(distances, j) > array.get(distances, j + 1)
                    float tempDist = array.get(distances, j)
                    array.set(distances, j, array.get(distances, j + 1))
                    array.set(distances, j + 1, tempDist)
                    int tempIdx = array.get(indices, j)
                    array.set(indices, j, array.get(indices, j + 1))
                    array.set(indices, j + 1, tempIdx)

        float weightedSum = 0.0
        float weightSum = 0.0
        effectiveK := math.min(knnNeighbors, array.size(distances))
        if effectiveK > 0
            for i = 0 to effectiveK - 1
                int idx = array.get(indices, i)
                float dist = array.get(distances, i)
                float weight = dist < 0.0001 ? 1.0 : 1.0 / dist

                float neighborRsi = src[idx]
                weightedSum += neighborRsi * weight
                weightSum += weight

                float futureReturn = close[idx - 5] - close[idx]
                if futureReturn > close[idx] * 0.02
                    array.push(overBoughtCandidates, src[idx])
                if futureReturn < close[idx] * -0.02
                    array.push(overSoldCandidates, src[idx])

            if weightSum > 0.0
                float knnRsi = weightedSum / weightSum
                enhancedRsi := (1.0 - knnWeight) * src + knnWeight * knnRsi
                enhancedRsi := math.max(0.0, math.min(100.0, enhancedRsi))

                float diffSum = 0.0
                int cnt = 0
                for i = 0 to effectiveK - 1
                    int idx = array.get(indices, i)
                    diffSum += math.abs(src - src[idx])
                    cnt += 1
                knnDivergence := cnt > 0 ? diffSum / cnt : 0.0

    adaptiveOverboughtMl := array.size(overBoughtCandidates) > 0 ? array.avg(overBoughtCandidates) : 70.0
    adaptiveOversoldMl := array.size(overSoldCandidates) > 0 ? array.avg(overSoldCandidates) : 30.0

    [enhancedRsi, knnDivergence, effectiveK, adaptiveOversoldMl, adaptiveOverboughtMl]

[knnRsi, knnDivergence, kEffective, adaptiveOversoldMl, adaptiveOverboughtMl] = knnEnhancedRsi(standardRsi)
float actualOverbought = rsiOverbought
float actualOversold = rsiOversold
float mlRsi = useKnn ? knnRsi : standardRsi

float filteredRsi = switch filterMethod
    "None" => mlRsi
    "Kalman" =>
        var float kfRsi = na
        kfRsi := na(kfRsi) ? mlRsi : kfRsi + filterStrength * (mlRsi - kfRsi)
        kfRsi
    "DoubleEMA" =>
        int dLenFast = math.max(1, math.round(filterStrength * 10))
        int dLenSlow = math.max(1, math.round(filterStrength * 5))
        float ema1 = ta.ema(mlRsi, dLenFast)
        ta.ema(ema1, dLenSlow)
    "ALMA" =>
        int aLen = math.max(1, math.round(filterStrength * 20))
        ta.alma(mlRsi, aLen, 0.0, 6.0)
    => mlRsi

float finalRsi = useFilter ? filteredRsi : mlRsi

[bullColor, bearColor] = switch colorScheme
    "Classic" => [neonEffect ? color.rgb(0, 255, 187) : color.rgb(0, 183, 18), neonEffect ? color.rgb(255, 17, 0) : color.rgb(195, 0, 16)]
    "Deuteranopia" => [color.rgb(0, 170, 255), color.rgb(255, 204, 0)]
    "Protanopia" => [color.rgb(0, 170, 230), color.rgb(230, 175, 0)]
    "Tritanopia" => [color.rgb(255, 112, 0), color.rgb(0, 33, 171)]
    => [color.rgb(222, 226, 230), color.rgb(73, 80, 87)]

color barBullColor = #0A7884
color barBearColor = #C60000

color indicatorColor = switch colorMode
    "None" => na
    "Trend Following" => finalRsi > 50 ? bullColor : bearColor
    "Impulse" => finalRsi > actualOverbought ? bullColor : finalRsi < actualOversold ? bearColor : finalRsi < 55 and finalRsi > 45 ? color.white : color.gray
    => na

barcolor(showBarColors ? color.new(finalRsi > 50 ? barBullColor : barBearColor, barColorAlpha) : na)

//=====================
// MA crossover (Source B logic family)
//=====================
float xMA = ta.sma(close, lengthMA)
float xEMA = ta.ema(xMA, lengthEMA)
bool maBull = xEMA > xMA
bool maBear = xEMA < xMA

//=====================
// Liquidity sweep
//=====================
int swingLookback = liqSweepLookbackBarsInput
float swingHigh = ta.highest(high, swingLookback)[1]
float swingLow = ta.lowest(low, swingLookback)[1]
bool liqSweepBull = low < swingLow and close > swingLow
bool liqSweepBear = high > swingHigh and close < swingHigh

//=====================
// HTF confluence (kept lightweight from Source A)
//=====================
float htfConfTolPct = 0.15
[htf1hHigh, htf1hLow] = request.security(syminfo.tickerid, "60", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf4hHigh, htf4hLow] = request.security(syminfo.tickerid, "240", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf1dHigh, htf1dLow] = request.security(syminfo.tickerid, "D", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

float htf1hRange = nz(htf1hHigh - htf1hLow)
float htf4hRange = nz(htf4hHigh - htf4hLow)
float htf1dRange = nz(htf1dHigh - htf1dLow)

htfFibPrice(float htfHigh, float htfLow, float htfRng, float ratio) =>
    htfRng <= 0 ? na : htfLow + htfRng * ratio

float htf1hP382 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_382)
float htf1hP500 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_PIVOT)
float htf1hP618 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_618)
float htf4hP382 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_382)
float htf4hP500 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_PIVOT)
float htf4hP618 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_618)
float htf1dP382 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_382)
float htf1dP500 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_PIVOT)
float htf1dP618 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_618)

htfConfluenceCheck(float level15m, float currentFibRange) =>
    if na(level15m) or na(currentFibRange) or currentFibRange <= 0
        0
    else
        float tol = currentFibRange * htfConfTolPct * 0.01
        int hits = 0
        if not na(htf1hP382) and math.abs(level15m - htf1hP382) <= tol
            hits += 1
        if not na(htf1hP500) and math.abs(level15m - htf1hP500) <= tol
            hits += 1
        if not na(htf1hP618) and math.abs(level15m - htf1hP618) <= tol
            hits += 1
        if not na(htf4hP382) and math.abs(level15m - htf4hP382) <= tol
            hits += 1
        if not na(htf4hP500) and math.abs(level15m - htf4hP500) <= tol
            hits += 1
        if not na(htf4hP618) and math.abs(level15m - htf4hP618) <= tol
            hits += 1
        if not na(htf1dP382) and math.abs(level15m - htf1dP382) <= tol
            hits += 1
        if not na(htf1dP500) and math.abs(level15m - htf1dP500) <= tol
            hits += 1
        if not na(htf1dP618) and math.abs(level15m - htf1dP618) <= tol
            hits += 1
        hits

//=====================
// AUTO FIB ENGINE — core anchor ownership from Source A
//=====================
fibZzUpdate() =>
    var fibSettings = zigzag.Settings.new(fibDeviation, fibDepth, color(na), false, false, false, false, "Absolute", true)
    var fibZZ = zigzag.newInstance(fibSettings)
    zigzag.Pivot lastPvt = na
    fibSettings.devThreshold := math.max(ta.atr(10) / close * 100 * fibDeviation, fibThresholdFloorPct)
    bool newPivot = false
    float pivotHighPrice = na
    float pivotLowPrice = na
    int pivotHighBar = na
    int pivotLowBar = na
    int swingDir = 0
    if fibZZ.update()
        lastPvt := fibZZ.lastPivot()
        if not na(lastPvt)
            newPivot := true
            float startP = lastPvt.start.price
            float endP = lastPvt.end.price
            pivotHighPrice := math.max(startP, endP)
            pivotLowPrice := math.min(startP, endP)
            swingDir := endP > startP ? 1 : endP < startP ? -1 : 0
            if startP >= endP
                pivotHighBar := lastPvt.start.index
                pivotLowBar := lastPvt.end.index
            else
                pivotHighBar := lastPvt.end.index
                pivotLowBar := lastPvt.start.index
    [newPivot, pivotHighPrice, pivotLowPrice, pivotHighBar, pivotLowBar, swingDir]

[zzNewPivot, zzHighPrice, zzLowPrice, zzHighBar, zzLowBar, zzSwingDir] = fibZzUpdate()

var float fibAnchorHigh = na
var float fibAnchorLow = na
var int anchorHighBar = na
var int anchorLowBar = na
var int lastBreakBar = na

if zzNewPivot
    fibAnchorHigh := zzHighPrice
    fibAnchorLow := zzLowPrice
    anchorHighBar := zzHighBar
    anchorLowBar := zzLowBar
    lastBreakBar := na

float fibRange = fibAnchorHigh - fibAnchorLow
float minFibRange = minFibRangeAtr * atr14
bool isValid = not na(fibAnchorHigh) and not na(fibAnchorLow) and fibRange >= minFibRange

float fibMidpoint = fibAnchorLow + fibRange * 0.5
float fibHystBand = fibRange * (fibHysteresisPct * 0.01)

var bool fibBull = true
if isValid
    if close >= fibMidpoint + fibHystBand
        fibBull := true
    else if close <= fibMidpoint - fibHystBand
        fibBull := false
else
    fibBull := true

float fibBase = fibBull ? fibAnchorLow : fibAnchorHigh
float fibDir = fibBull ? 1.0 : -1.0
fibPrice(float ratio) =>
    fibRange <= 0 ? na : fibBase + fibDir * fibRange * ratio

float pZero = fibPrice(FIB_ZERO)
float pNeg236 = fibPrice(-FIB_236)
float p236 = fibPrice(FIB_236)
float p382 = fibPrice(FIB_382)
float pPivot = fibPrice(FIB_PIVOT)
float p618 = fibPrice(FIB_618)
float p786 = fibPrice(FIB_786)
float pOne = fibPrice(FIB_ONE)
float pT1 = fibPrice(FIB_T1)
float p1272 = fibPrice(FIB_1272)
float p1382 = fibPrice(FIB_W1382)
float p150 = fibPrice(FIB_W150)
float pT2 = fibPrice(FIB_T2)
float p1786 = fibPrice(FIB_W1786)
float pT3 = fibPrice(FIB_T3)
float pT4 = fibPrice(FIB_T4)
float pT5 = fibPrice(FIB_T5)

float entryZoneUpper = math.max(pPivot, p786)
float entryZoneLower = math.min(pPivot, p786)
float zoneUpper = math.max(p618, p786)
float zoneLower = math.min(p618, p786)
float zoneFillUpper = math.max(p382, p618)
float zoneFillLower = math.min(p382, p618)

float confluenceQuality = na
if isValid
    float anchorRange = fibRange
    float tol = anchorRange * fibConfluenceTolPct * 0.01
    int confHits = 0
    float[] rH = array.from(ta.highest(high, 8), ta.highest(high, 13), ta.highest(high, 21), ta.highest(high, 34), ta.highest(high, 55))
    float[] rL = array.from(ta.lowest(low, 8), ta.lowest(low, 13), ta.lowest(low, 21), ta.lowest(low, 34), ta.lowest(low, 55))
    for i = 0 to 4
        float rollingH = array.get(rH, i)
        float rollingL = array.get(rL, i)
        float rollingRange = rollingH - rollingL
        if rollingRange > 0
            float a382 = fibAnchorLow + anchorRange * FIB_382
            float a500 = fibAnchorLow + anchorRange * FIB_PIVOT
            float a618 = fibAnchorLow + anchorRange * FIB_618
            float r382 = rollingL + rollingRange * FIB_382
            float r500 = rollingL + rollingRange * FIB_PIVOT
            float r618 = rollingL + rollingRange * FIB_618
            if math.abs(a382 - r382) <= tol
                confHits += 1
            if math.abs(a500 - r500) <= tol
                confHits += 1
            if math.abs(a618 - r618) <= tol
                confHits += 1
    confluenceQuality := float(confHits) * anchorRange

float htfRangeForConfluence = fibRange
int htfConfPivot = htfConfluenceCheck(pPivot, htfRangeForConfluence)
int htfConf382 = htfConfluenceCheck(p382, htfRangeForConfluence)
int htfConf618 = htfConfluenceCheck(p618, htfRangeForConfluence)
int htfConfTotal = htfConfPivot + htfConf382 + htfConf618

//=====================
// Structure conditions
//=====================
bool confirmed = barstate.isconfirmed
int dir = fibBull ? 1 : -1
bool zoneReady = not na(zoneUpper) and not na(zoneLower) and not na(pPivot)
bool breakInDir = zoneReady and confirmed ? (dir == 1 ? close > zoneUpper and close[1] <= zoneUpper : close < zoneLower and close[1] >= zoneLower) : false
if breakInDir
    lastBreakBar := bar_index
int barsSinceBreak = na(lastBreakBar) ? int(na) : bar_index - lastBreakBar
bool acceptInDir = zoneReady and confirmed and not na(barsSinceBreak) and barsSinceBreak > 0 and barsSinceBreak <= retestBars and (dir == 1 ? low <= zoneUpper and close > zoneUpper : high >= zoneLower and close < zoneLower)
bool rejectAtZone = zoneReady and confirmed and (rejectWick ? (dir == 1 ? high >= zoneLower and close < zoneLower : low <= zoneUpper and close > zoneUpper) : (dir == 1 ? close < zoneLower : close > zoneUpper))

bool entryZoneTouched = not na(entryZoneUpper) and not na(entryZoneLower) and high >= entryZoneLower and low <= entryZoneUpper
float optEntryRatio = optEntryLevelInput == "0.500" ? FIB_PIVOT : optEntryLevelInput == "0.786" ? FIB_786 : FIB_618
float entryLevel = fibPrice(optEntryRatio)
bool entryAnchorLong = confirmed and not na(entryLevel) and low <= entryLevel and close >= entryLevel
bool entryAnchorShort = confirmed and not na(entryLevel) and high >= entryLevel and close <= entryLevel

bool mlLongBias = finalRsi > 50 or ta.crossover(finalRsi, actualOversold)
bool mlShortBias = finalRsi < 50 or ta.crossunder(finalRsi, actualOverbought)
bool shortGate = gateShortsInBullTrend and maBull and finalRsi >= shortGateRsiFloor

bool longStructureOk = requireAcceptRetest ? (dir == 1 and acceptInDir) : (dir == 1 and (acceptInDir or rejectAtZone))
bool shortStructureOk = requireAcceptRetest ? (dir == -1 and acceptInDir) : (dir == -1 and (acceptInDir or rejectAtZone))
bool longPatternOk = not usePatternConfirm or provenBullishPattern
bool shortPatternOk = not usePatternConfirm or provenBearishPattern
bool longSweepOk = not useLiquiditySweepConfirm or liqSweepBull
bool shortSweepOk = not useLiquiditySweepConfirm or liqSweepBear
bool maLongOk = not useMaGate or (maBull and close >= xEMA)
bool maShortOk = not useMaGate or (maBear and close <= xEMA)
bool mlLongOk = not useMlFilter or mlLongBias
bool mlShortOk = not useMlFilter or mlShortBias

bool longCore = confirmed and isValid and entryZoneTouched and entryAnchorLong and longStructureOk and longPatternOk and longSweepOk and maLongOk and mlLongOk
bool shortCore = confirmed and isValid and entryZoneTouched and entryAnchorShort and shortStructureOk and shortPatternOk and shortSweepOk and maShortOk and mlShortOk and not shortGate

var int lastSignalBar = na
bool cooldownOk = na(lastSignalBar) or bar_index - lastSignalBar >= signalCooldownBars
bool longSignalRaw = longCore and cooldownOk
bool shortSignalRaw = shortCore and cooldownOk
bool entryLongTrigger = oneShotEvent ? (longSignalRaw and not longSignalRaw[1]) : longSignalRaw
bool entryShortTrigger = oneShotEvent ? (shortSignalRaw and not shortSignalRaw[1]) : shortSignalRaw
if entryLongTrigger or entryShortTrigger
    lastSignalBar := bar_index

// Exhaustion: opposite proven pattern at extension zone with ML extremes
bool extensionTouch = not na(p1272) and not na(pT2) and (dir == 1 ? (high >= p1272 - atr14 * exhaustionLevelAtrTol or high >= pT2 - atr14 * exhaustionLevelAtrTol) : (low <= p1272 + atr14 * exhaustionLevelAtrTol or low <= pT2 + atr14 * exhaustionLevelAtrTol))
bool exhaustionLong = useExhaustion and confirmed and dir == 1 and extensionTouch and provenBearishPattern and finalRsi >= actualOverbought
bool exhaustionShort = useExhaustion and confirmed and dir == -1 and extensionTouch and provenBullishPattern and finalRsi <= actualOversold

//=====================
// Draw fib ladder
//=====================
fibLineStyle = f_line_style(fibLineStyleInput)
fibLabelSize = f_label_size(fibLabelSizeInput)

var line lineZero = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineNeg236 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line236 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line382 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePivot = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line618 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line786 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineOne = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT1 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line1382 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line150 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT2 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line1786 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT3 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT4 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT5 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)

var box zoneBox = box.new(bar_index, close, bar_index, close, bgcolor=color(na), border_color=color(na))

var label _fibLblZero = na
var label _fibLblNeg236 = na
var label _fibLbl236 = na
var label _fibLbl382 = na
var label _fibLblPivot = na
var label _fibLbl618 = na
var label _fibLbl786 = na
var label _fibLblOne = na
var label _fibLblT1 = na
var label _fibLbl1382 = na
var label _fibLbl150 = na
var label _fibLblT2 = na
var label _fibLbl1786 = na
var label _fibLblT3 = na
var label _fibLblT4 = na
var label _fibLblT5 = na

int fallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
bool anchorBarsReady = not na(anchorHighBar) and not na(anchorLowBar)
int anchorStartBar = anchorBarsReady ? int(math.max(0, math.min(anchorHighBar, anchorLowBar))) : fallbackLeftBar
int drawLeftBarBase = useConfluenceAnchorSpan ? anchorStartBar : fallbackLeftBar
int drawLeftBar = int(math.max(drawLeftBarBase, anchorStartBar))

drawAnchoredLine(line id, bool visible, float price, color col, int width_, int leftBar) =>
    if visible and not na(price)
        int clampedLeftBar = int(math.max(leftBar, anchorStartBar))
        int rightBar = extendLevelsRight ? bar_index + fibLabelOffsetBarsInput : bar_index
        line.set_xy1(id, clampedLeftBar, price)
        line.set_xy2(id, rightBar, price)
        line.set_color(id, col)
        line.set_width(id, width_)
        line.set_style(id, fibLineStyle)
        line.set_extend(id, extend.none)
    else
        line.set_color(id, color(na))

setFibLevelLabel(label idIn, bool visible, float price, string txt, color col) =>
    label id = idIn
    if visible and isValid and not na(price)
        int labelX = bar_index + fibLabelOffsetBarsInput
        string labelText = txt + "  " + str.tostring(price, format.mintick)
        if na(id)
            id := label.new(labelX, price, labelText, style=label.style_label_left, color=color.new(color.black, 70), textcolor=col, size=fibLabelSize)
        label.set_xy(id, labelX, price)
        label.set_text(id, labelText)
        label.set_color(id, color.new(color.black, 70))
        label.set_textcolor(id, col)
        label.set_size(id, fibLabelSize)
    else if not na(id)
        label.delete(id)
        id := na
    id

drawAnchoredLine(lineZero, true, pZero, fibAnchorColorInput, fibAnchorWidthInput, drawLeftBar)
drawAnchoredLine(lineNeg236, false, pNeg236, fibStopColorInput, fibStopWidthInput, drawLeftBar)
drawAnchoredLine(line236, true, p236, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar)
drawAnchoredLine(line382, true, p382, fibRetracementAccentColorInput, fibRetracementAccentWidthInput, drawLeftBar)
drawAnchoredLine(linePivot, true, pPivot, fibAnchorColorInput, fibPivotWidthInput, drawLeftBar)
drawAnchoredLine(line618, true, p618, fibRetracementAccentColorInput, fibRetracementAccentWidthInput, drawLeftBar)
drawAnchoredLine(line786, true, p786, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar)
drawAnchoredLine(lineOne, true, pOne, fibAnchorColorInput, fibAnchorWidthInput, drawLeftBar)
drawAnchoredLine(lineT1, true, pT1, fibTargetColorInput, fibTargetWidthInput, drawLeftBar)
drawAnchoredLine(line1382, true, p1382, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar)
drawAnchoredLine(line150, true, p150, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar)
drawAnchoredLine(lineT2, true, pT2, fibTargetColorInput, fibTargetWidthInput, drawLeftBar)
drawAnchoredLine(line1786, true, p1786, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar)
drawAnchoredLine(lineT3, true, pT3, fibTargetColorInput, fibTargetWidthInput, drawLeftBar)
drawAnchoredLine(lineT4, true, pT4, fibTargetColorInput, fibTargetWidthInput, drawLeftBar)
drawAnchoredLine(lineT5, true, pT5, fibTargetColorInput, fibTargetWidthInput, drawLeftBar)

if not na(zoneFillUpper) and not na(zoneFillLower)
    box.set_left(zoneBox, drawLeftBar)
    box.set_right(zoneBox, bar_index)
    box.set_top(zoneBox, zoneFillUpper)
    box.set_bottom(zoneBox, zoneFillLower)
    box.set_bgcolor(zoneBox, color.new(fibPivotColorInput, zoneFillTransparencyInput))
    box.set_border_color(zoneBox, color.new(fibPivotColorInput, 100))
else
    box.set_bgcolor(zoneBox, color(na))
    box.set_border_color(zoneBox, color(na))

if barstate.islast
    _fibLblZero := setFibLevelLabel(_fibLblZero, showFibLevelLabelsInput, pZero, "0", fibAnchorColorInput)
    _fibLblNeg236 := setFibLevelLabel(_fibLblNeg236, false, pNeg236, "-.236", fibStopColorInput)
    _fibLbl236 := setFibLevelLabel(_fibLbl236, showFibLevelLabelsInput, p236, ".236", fibRetracementColorInput)
    _fibLbl382 := setFibLevelLabel(_fibLbl382, showFibLevelLabelsInput, p382, ".382", fibRetracementAccentColorInput)
    _fibLblPivot := setFibLevelLabel(_fibLblPivot, showFibLevelLabelsInput, pPivot, ".500", fibAnchorColorInput)
    _fibLbl618 := setFibLevelLabel(_fibLbl618, showFibLevelLabelsInput, p618, ".618", fibRetracementAccentColorInput)
    _fibLbl786 := setFibLevelLabel(_fibLbl786, showFibLevelLabelsInput, p786, ".786", fibRetracementColorInput)
    _fibLblOne := setFibLevelLabel(_fibLblOne, showFibLevelLabelsInput, pOne, "1.000", fibAnchorColorInput)
    _fibLblT1 := setFibLevelLabel(_fibLblT1, showFibLevelLabelsInput, pT1, "T1", fibTargetColorInput)
    _fibLbl1382 := setFibLevelLabel(_fibLbl1382, showFibLevelLabelsInput, p1382, "1.382", fibRetracementColorInput)
    _fibLbl150 := setFibLevelLabel(_fibLbl150, showFibLevelLabelsInput, p150, "1.500", fibRetracementColorInput)
    _fibLblT2 := setFibLevelLabel(_fibLblT2, showFibLevelLabelsInput, pT2, "T2", fibTargetColorInput)
    _fibLbl1786 := setFibLevelLabel(_fibLbl1786, showFibLevelLabelsInput, p1786, "1.786", fibRetracementColorInput)
    _fibLblT3 := setFibLevelLabel(_fibLblT3, showFibLevelLabelsInput, pT3, "T3", fibTargetColorInput)
    _fibLblT4 := setFibLevelLabel(_fibLblT4, showFibLevelLabelsInput, pT4, "T4", fibTargetColorInput)
    _fibLblT5 := setFibLevelLabel(_fibLblT5, showFibLevelLabelsInput, pT5, "T5", fibTargetColorInput)

plot(showMaLines ? xMA : na, "MA (SMA)", maColorInput, maWidthInput)
plot(showMaLines ? xEMA : na, "EMA(on MA)", emaColorInput, emaWidthInput)

//=====================
// ML table
//=====================
string modeUsed = colorMode
string context = switch colorMode
    "Trend Following" => finalRsi > 50 ? "Bullish Trend" : "Bearish Trend"
    "Impulse" => finalRsi > actualOverbought ? "Bullish Impulse" : finalRsi < actualOversold ? "Bearish Impulse" : "None"
    => "None"
string mlStatus = useKnn ? "YES" : "NO"
string signalState = entryLongTrigger ? "LONG" : entryShortTrigger ? "SHORT" : exhaustionLong ? "EXH-LONG" : exhaustionShort ? "EXH-SHORT" : "IDLE"

var table mlTable = na
if barstate.isfirst and showMlTable
    mlTable := table.new(f_table_pos(tablePositionInput), 2, 6, bgcolor=#160d0db3, border_color=#160d0db3, border_width=1, frame_color=color.white, frame_width=1, force_overlay=true)

if showMlTable and not na(mlTable) and bar_index % 10 == 0
    table.cell(mlTable, 0, 0, "Mode", text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 1, 0, modeUsed, text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 0, 1, "Context", text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 1, 1, context, text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 0, 2, "Machine Learning", text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 1, 2, mlStatus, text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 0, 3, "OB/OS", text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 1, 3, str.tostring(actualOverbought) + " / " + str.tostring(actualOversold), text_color=color.white, bgcolor=color.new(color.black, 70))
    table.cell(mlTable, 0, 4, "RSI", text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 1, 4, str.tostring(finalRsi, "#.##"), text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 0, 5, "State", text_color=color.white, bgcolor=#160d0db3)
    table.cell(mlTable, 1, 5, signalState, text_color=color.white, bgcolor=#160d0db3)

//=====================
// Hidden Optuna exports
//=====================
plot(fibRange, "fib_range", display=display.none, editable=false)
plot(float(dir), "ml_direction_code", display=display.none, editable=false)
plot(nz(confluenceQuality), "confluence_quality", display=display.none, editable=false)
plot(float(htfConfPivot), "htf_conf_pivot", display=display.none, editable=false)
plot(float(htfConf382), "htf_conf_382", display=display.none, editable=false)
plot(float(htfConf618), "htf_conf_618", display=display.none, editable=false)
plot(float(htfConfTotal), "htf_conf_total", display=display.none, editable=false)

plot(finalRsi, "ml_rsi_value", display=display.none, editable=false)
plot(knnDivergence, "ml_knn_divergence", display=display.none, editable=false)
plot(float(kEffective), "ml_knn_effective_k", display=display.none, editable=false)
plot(useKnn ? 1.0 : 0.0, "ml_knn_enabled", display=display.none, editable=false)
plot(useFilter ? 1.0 : 0.0, "ml_filter_enabled", display=display.none, editable=false)
plot(actualOverbought, "ml_overbought", display=display.none, editable=false)
plot(actualOversold, "ml_oversold", display=display.none, editable=false)

plot(xMA, "ml_ma_sma", display=display.none, editable=false)
plot(xEMA, "ml_ema_of_ma", display=display.none, editable=false)
plot(maBull ? 1.0 : maBear ? -1.0 : 0.0, "ml_ma_bias", display=display.none, editable=false)

plot(provenBullishPattern ? 1.0 : 0.0, "ml_bull_pattern", display=display.none, editable=false)
plot(provenBearishPattern ? 1.0 : 0.0, "ml_bear_pattern", display=display.none, editable=false)
plot(liqSweepBull ? 1.0 : liqSweepBear ? -1.0 : 0.0, "ml_liq_sweep", display=display.none, editable=false)
plot(acceptInDir ? 1.0 : 0.0, "ml_accept_in_dir", display=display.none, editable=false)
plot(rejectAtZone ? 1.0 : 0.0, "ml_reject_zone", display=display.none, editable=false)
plot(entryLongTrigger ? 1.0 : 0.0, "ml_entry_long_trigger", display=display.none, editable=false)
plot(entryShortTrigger ? 1.0 : 0.0, "ml_entry_short_trigger", display=display.none, editable=false)
plot(exhaustionLong ? 1.0 : 0.0, "ml_exhaustion_long", display=display.none, editable=false)
plot(exhaustionShort ? 1.0 : 0.0, "ml_exhaustion_short", display=display.none, editable=false)
