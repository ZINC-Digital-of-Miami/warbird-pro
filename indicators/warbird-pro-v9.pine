//@version=6
// This Pine Script code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Kirk / ZINC Digital
//
// Warbird Pro V9 — Fib Anchor + Liquidity + Cross-Asset + Footprint
// Source ownership:
// - Fib engine/ladder math: Indicator A (PROTECTED — anchor ownership, ZigZag, ratios)
// - MA gate: price above BOTH primary EMA and smoothing MA = bull; below both = bear
// - RSI context
//
// Design contract:
// - Fib core remains untouched (anchor ownership, ladder math, draw span)
// - When a trade fires: ALL fibs (lines, labels, zone box) hide; ENTRY/SL/TP
//   lines and labels reuse the SAME drawAnchoredLine + setFibLevelLabel
//   plumbing with the same widths, styles, label sizes, and label offsets
// - Liquidity is its own first-class package: BSL/SSL sweep+reclaim,
//   equal-highs/lows pools, session VWAP context, volume z-score
// - Cross-asset: NQ + 6E trend codes + ES↔NQ rolling correlation
//   (6E replaces DXY as USD-pressure proxy 2026-05-11; ZN and VIX removed 2026-05-13)
// - Daily/weekly S/R: PDH/PDL/PWH/PWL distance features + thin lines
// - Footprint: real intrabar bid/ask delta + POC distance + VA position
// - Unified entry: trigger fires only when trade engine actually opens a trade
//
// NO-REPAINT AUDIT:
// - Structural triggers gated by barstate.isconfirmed
// - request.security() calls use lookahead_off with [1]-offset for HTF
// - ZigZag pivots consumed only after confirmation from library output
// - Liquidity reclaim uses bar[1] swept + bar[0] reclaimed (history-only)
indicator("Warbird Pro V9", shorttitle="Warbird V9", overlay=true, max_lines_count=80, max_labels_count=200, max_boxes_count=8)
import TradingView/ZigZag/7 as zigzag

//=====================
// FIBONACCI ENGINE SETTINGS (Source A — PROTECTED)
//=====================
string groupFibEngine = "Fib Structure"
bool autoTuneZZ = input.bool(false, "Auto-tune ZigZag by Timeframe", group=groupFibEngine)
float fibDeviationManual = input.float(3.0, "ZigZag Deviation (manual)", minval=0.5, maxval=20.0, step=0.5, group=groupFibEngine)
int fibDepthManual = input.int(10, "ZigZag Depth (manual)", minval=2, maxval=80, group=groupFibEngine)
float fibThresholdFloorPct = input.float(0.25, "ZigZag Threshold Floor (%)", minval=0.0, maxval=5.0, step=0.05, group=groupFibEngine)
float minFibRangeAtr = input.float(0.5, "Min Fib Range (ATR)", minval=0.2, maxval=10.0, step=0.1, group=groupFibEngine)
float fibHysteresisPct = input.float(2.0, "Midpoint Hysteresis (%)", minval=0.1, maxval=10.0, step=0.1, group=groupFibEngine)

int _tfSec = timeframe.in_seconds()
float fibDeviation = autoTuneZZ ? (_tfSec >= 14400 ? 4.0 : _tfSec >= 3600 ? 3.5 : _tfSec >= 900 ? 4.0 : 3.0) : fibDeviationManual
int fibDepth = autoTuneZZ ? (_tfSec >= 14400 ? 20 : _tfSec >= 3600 ? 15 : _tfSec >= 900 ? 20 : 15) : fibDepthManual

//=====================
// CANONICAL FIB LEVELS (Source A — PROTECTED)
//=====================
float FIB_ZERO  = 0.0
float FIB_236   = 0.236
float FIB_382   = 0.382
float FIB_PIVOT = 0.5
float FIB_618   = 0.618
float FIB_786   = 0.786
float FIB_ONE   = 1.0

float FIB_T1    = 1.236
float FIB_1272  = 1.272
float FIB_W1382 = 1.382
float FIB_W150  = 1.5
float FIB_T2    = 1.618
float FIB_W1786 = 1.786
float FIB_T3    = 2.0
float FIB_T4    = 2.236
float FIB_T5    = 2.618

color COLOR_ANCHOR             = #FFFFFF
color COLOR_RETRACEMENT        = #808080
color COLOR_RETRACEMENT_ACCENT = #B83B55
color COLOR_PIVOT              = #B0B0B0
color COLOR_TARGET             = #006064
color COLOR_STOP               = #CB3F3B

int WIDTH_ANCHOR      = 2
int WIDTH_RETRACEMENT = 1
int WIDTH_PIVOT       = 1
int WIDTH_TARGET      = 1

//=====================
// TRADE INFLUENCES
//=====================
string groupInfluences = "Trade Influences"
bool useXaInfluence = input.bool(true, "Enable NQ/6E Influence", group=groupInfluences)
bool useLiquidityInfluence = input.bool(true, "Enable Liquidity Influence", group=groupInfluences)
bool useFootprint = input.bool(true, "Enable Footprint Influence", group=groupInfluences)

// Influence internals are intentionally not user-facing knobs. The public
// influence toggles keep the existing gate behavior while the hidden aliases
// preserve the deterministic AG/export surface.
int LIQ_LOOKBACK_BARS = 10
int LIQ_RECENCY_BARS = 1
int EQH_TOL_PCT = 5
int EQH_MIN_TAPS = 2
int EQH_LOOKBACK = 50
int VOL_Z_LENGTH = 10
string XA_TREND_TIMEFRAME = "15"
string NQ_SYMBOL = "CME_MINI:NQ1!"
string EUR_USD_SYMBOL = "CME:6E1!"
int XA_CORR_LENGTH = 5
int FP_TICKS_PER_ROW = 4
float FP_VA_PCT = 70.0
float FP_IMBALANCE_PCT = 300.0
float FP_ABSORPTION_DELTA_PCT = 20.0
float FP_FLUSH_DELTA_PCT = 20.0
float FP_EVENT_VOL_SPIKE = 1.50
float FP_COMPRESSED_RANGE_ATR = 0.75

// Hidden compatibility aliases for existing feature calculations. Keep the
// operator settings surface narrow while preserving the established V9 export
// column semantics until the influence architecture is reviewed separately.
bool useLiqGate = useLiquidityInfluence
int liqRecencyBars = LIQ_RECENCY_BARS
int liqLookbackBars = LIQ_LOOKBACK_BARS
int eqhTolPct = EQH_TOL_PCT
int eqhMinTaps = EQH_MIN_TAPS
int eqhLookback = EQH_LOOKBACK
int volZLength = VOL_Z_LENGTH
bool useXaGate = useXaInfluence
string xaTrendTimeframe = XA_TREND_TIMEFRAME
string nqSymbol = NQ_SYMBOL
string eurUsdSymbol = EUR_USD_SYMBOL
int corrLength = XA_CORR_LENGTH
int xaMinAgreement = 2
int fpTicksPerRow = FP_TICKS_PER_ROW
float fpVaPct = FP_VA_PCT
float fpImbalancePct = FP_IMBALANCE_PCT
float fpAbsorptionDeltaPct = FP_ABSORPTION_DELTA_PCT
float fpFlushDeltaPct = FP_FLUSH_DELTA_PCT
float fpEventVolSpike = FP_EVENT_VOL_SPIKE
float fpCompressedRangeAtr = FP_COMPRESSED_RANGE_ATR

string groupExecution = "Trade Management"
// Combo selectors match AG trade-surface discoverables (locked 2026-05-11):
//   DISCOVERABLE_TP_RATIOS = (1.000, 1.236, 1.618, 2.000, 2.236)
//                                                            fib-extension targets
//   DISCOVERABLE_SL_ATR_MULTS = (0.75, 1.0, 1.5, 2.0)     ATR-scaled stops
//
// Operator should normally leave both on "Auto". AG scores all TP×SL combos
// per candidate off-chart and entry_decision_v9.py picks the EV-max combo
// at decision time. The manual combo overrides exist only so the operator
// can visually validate each combo's geometry during live-TV testing —
// changing them does NOT affect AG training or AG inference; only the
// chart's active-trade lines/labels move.
//
// Manual defaults mirror the current canonical chart (TP=1.618, SL=1.0).
// "Auto" still maps to (TP=1.236, SL=1.5) until a promoted AG combo replaces it.
string tpRatioMode = input.string("1.618", "TP Ratio (combo)", options=["Auto", "1.000", "1.236", "1.618", "2.000", "2.236"], group=groupExecution)
string slMultMode = input.string("1.0", "SL ATR Mult (combo)", options=["Auto", "1.0", "1.5", "2.0"], group=groupExecution)
float tradeTpRatio = tpRatioMode == "1.000" ? 1.000 : tpRatioMode == "1.618" ? 1.618 : tpRatioMode == "2.000" ? 2.000 : tpRatioMode == "2.236" ? 2.236 : 1.236
float tradeStopAtrMult = slMultMode == "1.0" ? 1.0 : slMultMode == "2.0" ? 2.0 : 1.5
int tradeMaxHoldBars = input.int(10, "Max Hold (bars)", minval=0, maxval=500, group=groupExecution)

//=====================
// Moving Average Exponential — pasted verbatim from TradingView built-in.
// Two extra lines at the bottom define the gate (price above/below both MAs).
//=====================
len = input.int(21, minval=1, title="Length")
src = input(close, title="Source")
offset = input.int(title="Offset", defval=1, minval=-500, maxval=500, display = display.none)
out = ta.ema(src, len)
plot(out, title="EMA", color=color.white, linewidth=2, offset=offset, display=display.all)

// Smoothing MA inputs
GRP = "Smoothing"
TT_BB = "Only applies when 'SMA + Bollinger Bands' is selected. Determines the distance between the SMA and the bands."
maTypeInput = input.string("EMA", "Type", options = ["None", "SMA", "SMA + Bollinger Bands", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group = GRP, display = display.none)
var isBB = maTypeInput == "SMA + Bollinger Bands"
maLengthInput = input.int(9, "Length", group = GRP, display = display.none, active = maTypeInput != "None")
bbMultInput = input.float(2.0, "BB StdDev", minval = 0.001, maxval = 50, step = 0.5, tooltip = TT_BB, group = GRP, display = display.none, active = isBB)
var enableMA = maTypeInput != "None"

// Smoothing MA Calculation
ma(source, length, MAtype) =>
	switch MAtype
		"SMA"                   => ta.sma(source, length)
		"SMA + Bollinger Bands" => ta.sma(source, length)
		"EMA"                   => ta.ema(source, length)
		"SMMA (RMA)"            => ta.rma(source, length)
		"WMA"                   => ta.wma(source, length)
		"VWMA"                  => ta.vwma(source, length)

// Smoothing MA plots
smoothingMA = enableMA ? ma(out, maLengthInput, maTypeInput) : na
smoothingStDev = isBB ? ta.stdev(out, maLengthInput) * bbMultInput : na
plot(smoothingMA, "EMA-based MA", color=#26A69A, linewidth=2, display = enableMA ? display.all : display.none, editable = enableMA)
// BB visuals are intentionally not plotted. The V9 export is at the Pine
// 64-output cap after adding TP4/TP5 ladder exports; keep the MA value and
// input surface, but do not spend output slots on non-default BB overlays.

// Gate: price above OR below BOTH MAs.
bool maBull = close > out and close > smoothingMA
bool maBear = close < out and close < smoothingMA

//=====================
// RSI CONTEXT (Source C)
//=====================
string groupRsi = "RSI Context"
int rsiLength = input.int(11, "RSI Length", minval=1, group=groupRsi)
float rsiOverbought = input.float(80.0, "Bearish Extreme Above", minval=50.0, maxval=100.0, step=0.1, group=groupRsi)
float rsiOversold = input.float(20.0, "Bullish Extreme Below", minval=0.0, maxval=50.0, step=0.1, group=groupRsi)

//=====================
// DAILY/WEEKLY S/R LEVELS
//=====================
string groupLvl = "D/W Levels"
bool showPdh = input.bool(true, "Show PDH", group=groupLvl, inline="pd")
bool showPdl = input.bool(true, "Show PDL", group=groupLvl, inline="pd")
bool showPwh = input.bool(true, "Show PWH", group=groupLvl, inline="pw")
bool showPwl = input.bool(true, "Show PWL", group=groupLvl, inline="pw")
color lvlDayColor = input.color(#808080, "Day Color", group=groupLvl, inline="dc")
color lvlWeekColor = input.color(#880E4F, "Week Color", group=groupLvl, inline="wc")

string groupTable = "Table"
bool showMlTable = input.bool(false, "Show ML Table", group=groupTable)
string tablePositionInput = input.string("Bottom Left", "Table Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=groupTable)
string tableTextSizeInput = input.string("Small", "Table Text Size", options=["Tiny", "Small", "Large"], group=groupTable)

//=====================
// FIB VISUAL SETTINGS (Source A — PROTECTED draw span)
//=====================
string groupViz = "Fib Visuals"
int targetLookbackBars = input.int(40, "Target Line Lookback Bars", minval=5, maxval=500, group=groupViz)
bool extendLevelsRight = input.bool(true, "Extend Levels Right", group=groupViz)
bool useConfluenceAnchorSpan = input.bool(true, "Anchor Span = Active Fib Window", group=groupViz)
color fibAnchorColorInput = input.color(COLOR_ANCHOR, "Anchor Fib", inline="fib_anchor", group=groupViz)
int fibAnchorWidthInput = input.int(WIDTH_ANCHOR, "", minval=1, maxval=5, inline="fib_anchor", group=groupViz)
string fibAnchorStyle = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_anchor", group=groupViz)
color fibStopColorInput = input.color(COLOR_ANCHOR, "Neg .236 / SL", inline="fib_stop", group=groupViz)
int fibStopWidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_stop", group=groupViz)
string fibStopStyle = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_stop", group=groupViz)
color fibRetracementColorInput = input.color(COLOR_RETRACEMENT, ".236/.786/Waypoints", inline="fib_retrace", group=groupViz)
int fibRetracementWidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_retrace", group=groupViz)
string fibRetraceStyle = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_retrace", group=groupViz)
color fibRetracementAccentColorInput = input.color(COLOR_ANCHOR, ".382/.618", inline="fib_accent", group=groupViz)
int fibRetracementAccentWidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_accent", group=groupViz)
string fibAccentStyle = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_accent", group=groupViz)
color fib500ColorInput = input.color(COLOR_ANCHOR, ".500", inline="fib_500", group=groupViz)
int fib500WidthInput = input.int(WIDTH_PIVOT, "", minval=1, maxval=5, inline="fib_500", group=groupViz)
string fib500Style = input.string("Dashed", "", options=["Solid", "Dashed", "Dotted"], inline="fib_500", group=groupViz)
color fib618ColorInput = input.color(COLOR_ANCHOR, ".618", inline="fib_618", group=groupViz)
int fib618WidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_618", group=groupViz)
string fib618Style = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_618", group=groupViz)
color fib786ColorInput = input.color(COLOR_RETRACEMENT, ".786", inline="fib_786", group=groupViz)
int fib786WidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_786", group=groupViz)
string fib786Style = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_786", group=groupViz)
color fibOneColorInput = input.color(COLOR_ANCHOR, "1.000", inline="fib_1000", group=groupViz)
int fibOneWidthInput = input.int(WIDTH_ANCHOR, "", minval=1, maxval=5, inline="fib_1000", group=groupViz)
string fibOneStyle = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_1000", group=groupViz)
color fibPivotColorInput = input.color(COLOR_ANCHOR, "Pivot Zone", inline="fib_pivot", group=groupViz)
int fibPivotWidthInput = input.int(WIDTH_PIVOT, "", minval=1, maxval=5, inline="fib_pivot", group=groupViz)
string fibPivotStyle = input.string("Dashed", "", options=["Solid", "Dashed", "Dotted"], inline="fib_pivot", group=groupViz)
color fibTargetColorInput = input.color(#0097A7, "Targets / TP", inline="fib_target", group=groupViz)
int fibTargetWidthInput = input.int(WIDTH_TARGET, "", minval=1, maxval=5, inline="fib_target", group=groupViz)
string fibTargetStyle = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="fib_target", group=groupViz)
bool showFibLevelLabelsInput = input.bool(true, "Show Fib Level Labels", group=groupViz)
int fibLabelOffsetBarsInput = input.int(8, "Fib Label Offset (bars)", minval=0, maxval=30, group=groupViz)
string fibLabelSizeInput = input.string("Normal", "Fib Label Size", options=["Tiny", "Small", "Normal", "Large"], group=groupViz)
color fibLabelBgColorInput = input.color(color.new(color.black, 70), "Label BG", inline="fib_label_colors", group=groupViz)
color fibLabelFontColorInput = input.color(color.white, "Label Font", inline="fib_label_colors", group=groupViz)
int zoneFillTransparencyInput = input.int(75, "Zone Fill Alpha", minval=0, maxval=100, group=groupViz)

//=====================
// Helpers
//=====================
f_line_style(string styleName) =>
    styleName == "Dashed" ? line.style_dashed : styleName == "Dotted" ? line.style_dotted : line.style_solid

f_label_size(string sizeName) =>
    sizeName == "Tiny" ? size.tiny : sizeName == "Normal" ? size.normal : sizeName == "Large" ? size.large : size.small

f_table_pos(string p) =>
    p == "Top Left" ? position.top_left : p == "Bottom Right" ? position.bottom_right : p == "Bottom Left" ? position.bottom_left : position.top_right

f_xa_code(float c, float slow, float fast) =>
    na(c) or na(slow) or na(fast) ? 0 : (fast > slow and c > fast) ? 2 : (fast > slow) ? 1 : (fast < slow and c < fast) ? -2 : (fast < slow) ? -1 : 0

f_xa_label(int code) =>
    code == 2 ? "STRONG BULLISH" : code == 1 ? "BULLISH" : code == -2 ? "STRONG BEARISH" : code == -1 ? "BEARISH" : "NEUTRAL"

//=====================
// Base metrics
//=====================
float atr14 = ta.atr(14)
float barRange = high - low
bool bullishCandle = close > open
bool bearishCandle = close < open

//=====================
// RSI context
//=====================
float finalRsi = ta.rsi(close, rsiLength)

//=====================
// ADX components (AG feature export)
//=====================
int adxLength = 14
[adxDiPlus, adxDiMinus, adxValue] = ta.dmi(adxLength, adxLength)

//=====================
// Cross-asset trend codes (NQ + 6E only; ZN and VIX removed 2026-05-13)
//=====================
[nqClose5, nqSlow5, nqFast5] = request.security(nqSymbol, xaTrendTimeframe, [close, ta.sma(close, 21), ta.ema(close, 9)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[eurUsdClose5, eurUsdSlow5, eurUsdFast5] = request.security(eurUsdSymbol, xaTrendTimeframe, [close, ta.sma(close, 21), ta.ema(close, 9)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

int nqCode = f_xa_code(nqClose5, nqSlow5, nqFast5)
int eurUsdCode = f_xa_code(eurUsdClose5, eurUsdSlow5, eurUsdFast5)

float corrMesNq = ta.correlation(close, nqClose5, corrLength)

//=====================
// Multi-TF trend codes for table — same f_xa_code grading on chart symbol
// across 5m/15m/1h/4h. These are table-only context; they are NOT new
// AG features and do not consume plot budget (no plot() / no alertcondition()).
//=====================
[tfTrend5C, tfTrend5Slow, tfTrend5Fast] = request.security(syminfo.tickerid, "5", [close, ta.sma(close, 21), ta.ema(close, 9)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[tfTrend15C, tfTrend15Slow, tfTrend15Fast] = request.security(syminfo.tickerid, "15", [close, ta.sma(close, 21), ta.ema(close, 9)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[tfTrend60C, tfTrend60Slow, tfTrend60Fast] = request.security(syminfo.tickerid, "60", [close, ta.sma(close, 21), ta.ema(close, 9)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[tfTrend240C, tfTrend240Slow, tfTrend240Fast] = request.security(syminfo.tickerid, "240", [close, ta.sma(close, 21), ta.ema(close, 9)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
int tfTrend5Code = f_xa_code(tfTrend5C, tfTrend5Slow, tfTrend5Fast)
int tfTrend15Code = f_xa_code(tfTrend15C, tfTrend15Slow, tfTrend15Fast)
int tfTrend60Code = f_xa_code(tfTrend60C, tfTrend60Slow, tfTrend60Fast)
int tfTrend240Code = f_xa_code(tfTrend240C, tfTrend240Slow, tfTrend240Fast)

//=====================
// Liquidity pools (BSL/SSL) — minimal moving parts, 2-bar reclaim (1e/3d)
//=====================
float bsl = ta.highest(high, liqLookbackBars)[1]
float ssl = ta.lowest(low, liqLookbackBars)[1]

bool sweptBslBar = high > bsl and close < bsl
bool sweptSslBar = low < ssl and close > ssl

bool reclaimedBsl = sweptBslBar[1] and close < bsl
bool reclaimedSsl = sweptSslBar[1] and close > ssl

float bslDistAtr = atr14 > 0 ? (bsl - close) / atr14 : 0.0
float sslDistAtr = atr14 > 0 ? (close - ssl) / atr14 : 0.0

bool liqSweepBull = sweptSslBar or reclaimedSsl
bool liqSweepBear = sweptBslBar or reclaimedBsl
int barsSinceLiqBull = ta.barssince(liqSweepBull)
int barsSinceLiqBear = ta.barssince(liqSweepBear)

//=====================
// Equal Highs / Lows — true liquidity pools (price tagged within tolerance N+ times)
//=====================
float eqhTol = atr14 * (eqhTolPct / 100.0)
f_count_taps_high(float ref, int lookback, float tol) =>
    int taps = 0
    for i = 1 to lookback
        if math.abs(high[i] - ref) <= tol
            taps += 1
    taps
f_count_taps_low(float ref, int lookback, float tol) =>
    int taps = 0
    for i = 1 to lookback
        if math.abs(low[i] - ref) <= tol
            taps += 1
    taps
int hiTaps = f_count_taps_high(high, eqhLookback, eqhTol)
int loTaps = f_count_taps_low(low, eqhLookback, eqhTol)
bool isEqualHigh = hiTaps >= eqhMinTaps
bool isEqualLow = loTaps >= eqhMinTaps
var float lastEqHigh = na
var float lastEqLow = na
if isEqualHigh
    lastEqHigh := high
if isEqualLow
    lastEqLow := low
float eqhDistAtr = atr14 > 0 and not na(lastEqHigh) ? (lastEqHigh - close) / atr14 : 0.0
float eqlDistAtr = atr14 > 0 and not na(lastEqLow) ? (close - lastEqLow) / atr14 : 0.0

//=====================
// Session VWAP (hidden model/export feature, not an operator setting)
//=====================
float vwapRaw = ta.vwap(hlc3, timeframe.change("D"))
float vwap1 = vwapRaw
float vwapDistAtr = atr14 > 0 and not na(vwap1) ? (close - vwap1) / atr14 : 0.0

//=====================
// Volume z-score (real volume, not OHLCV-derived delta)
//=====================
float volMean = ta.sma(volume, volZLength)
float volSd = ta.stdev(volume, volZLength)
float volZscore = volSd > 0 ? (volume - volMean) / volSd : 0.0

//=====================
// HTF confluence
//=====================
float htfConfTolPct = input.float(1.5, "HTF Confluence Tolerance (%)", minval=0.1, maxval=10.0, step=0.1, group=groupFibEngine)
int htf1hLookback = input.int(8, "HTF 1H Lookback (bars)", minval=2, maxval=60, group=groupFibEngine)
[htf1hHigh, htf1hLow] = request.security(syminfo.tickerid, "60", [ta.highest(high, htf1hLookback), ta.lowest(low, htf1hLookback)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htfDHigh, htfDLow] = request.security(syminfo.tickerid, "D", [high[1], low[1]], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htfMHigh, htfMLow] = request.security(syminfo.tickerid, "M", [high[1], low[1]], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

//=====================
// Daily/weekly S/R levels — PDH/PDL/PWH/PWL (anti-repaint via [1] offset)
//=====================
[pdh, pdl, dailyOpen, dailyCloseConfirmed] = request.security(syminfo.tickerid, "D", [high[1], low[1], open, close[1]], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[pwh, pwl] = request.security(syminfo.tickerid, "W", [high[1], low[1]], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

float pdhDistAtr = atr14 > 0 and not na(pdh) ? (pdh - close) / atr14 : 0.0
float pdlDistAtr = atr14 > 0 and not na(pdl) ? (close - pdl) / atr14 : 0.0
float pwhDistAtr = atr14 > 0 and not na(pwh) ? (pwh - close) / atr14 : 0.0
float pwlDistAtr = atr14 > 0 and not na(pwl) ? (close - pwl) / atr14 : 0.0

//=====================
// Footprint — real intrabar bid/ask delta, POC, VAH/VAL
// API: methods (with parens), POC/VAH/VAL return volume_row objects (extract via .up_price/.down_price)
//=====================
float fpDeltaPct = 0.0
float fpPocDistAtr = 0.0
int fpVaPosition = 0
float fpDeltaVol = 0.0
float fpTotalVol = 0.0
float fpPocPrice = na
if useFootprint
    footprint fp = request.footprint(fpTicksPerRow, fpVaPct, fpImbalancePct)
    if not na(fp)
        float buyVol = fp.buy_volume()
        float sellVol = fp.sell_volume()
        float totalVol = buyVol + sellVol
        float deltaVol = fp.delta()
        fpTotalVol := totalVol
        fpDeltaVol := deltaVol
        fpDeltaPct := totalVol > 0 ? (deltaVol / totalVol) * 100.0 : 0.0
        volume_row pocRow = fp.poc()
        float pocPrice = na(pocRow) ? na : pocRow.up_price()
        fpPocPrice := pocPrice
        fpPocDistAtr := atr14 > 0 and not na(pocPrice) ? (close - pocPrice) / atr14 : 0.0
        volume_row vahRow = fp.vah()
        volume_row valRow = fp.val()
        float vah = na(vahRow) ? na : vahRow.up_price()
        float val_ = na(valRow) ? na : valRow.down_price()
        fpVaPosition := not na(vah) and close > vah ? 1 : not na(val_) and close < val_ ? -1 : 0

float fpDeltaAcceleration = fpDeltaVol - nz(fpDeltaVol[1])
float fpDeltaVolSd = ta.stdev(fpDeltaVol, volZLength)
float fpAggressorPulse = not na(fpDeltaVolSd) and fpDeltaVolSd > 0 ? fpDeltaVol / fpDeltaVolSd : 0.0
float fpVolumeMean = ta.sma(fpTotalVol, volZLength)
float fpVolumeSpikeRatio = not na(fpVolumeMean) and fpVolumeMean > 0 ? fpTotalVol / fpVolumeMean : 0.0
float fpPocShift = atr14 > 0 and not na(fpPocPrice) and not na(fpPocPrice[1]) ? (fpPocPrice - fpPocPrice[1]) / atr14 : 0.0
float fpRangeAtr = atr14 > 0 ? barRange / atr14 : 0.0
bool fpAbsorptionCandidate = math.abs(fpDeltaPct) >= fpAbsorptionDeltaPct and fpVolumeSpikeRatio >= fpEventVolSpike and fpRangeAtr <= fpCompressedRangeAtr
bool fpFlushCandidate = math.abs(fpDeltaPct) >= fpFlushDeltaPct and fpVolumeSpikeRatio >= fpEventVolSpike and fpRangeAtr > fpCompressedRangeAtr

float htf1hRange = nz(htf1hHigh - htf1hLow)

htfFibPrice(float htfHigh, float htfLow, float htfRng, float ratio, float htfDir) =>
    htfRng <= 0 ? na : (htfDir >= 0 ? htfLow + htfRng * ratio : htfHigh - htfRng * ratio)

htfConfluenceCheck(float chartLevel, float htfLevel, float currentFibRange) =>
    if na(chartLevel) or na(htfLevel) or na(currentFibRange) or currentFibRange <= 0
        0
    else
        float tol = currentFibRange * htfConfTolPct * 0.01
        math.abs(chartLevel - htfLevel) <= tol ? 1 : 0

//=====================
// AUTO FIB ENGINE (Source A — PROTECTED, unchanged)
//=====================
fibZzUpdate() =>
    var fibSettings = zigzag.Settings.new(fibDeviation, fibDepth, color(na), false, false, false, false, "Absolute", true)
    var fibZZ = zigzag.newInstance(fibSettings)
    zigzag.Pivot lastPvt = na
    fibSettings.devThreshold := math.max(ta.atr(10) / close * 100 * fibDeviation, fibThresholdFloorPct)
    bool newPivot = false
    float pivotHighPrice = na
    float pivotLowPrice = na
    int pivotHighBar = na
    int pivotLowBar = na
    int swingDir = 0
    if fibZZ.update()
        lastPvt := fibZZ.lastPivot()
        if not na(lastPvt)
            newPivot := true
            float startP = lastPvt.start.price
            float endP = lastPvt.end.price
            pivotHighPrice := math.max(startP, endP)
            pivotLowPrice := math.min(startP, endP)
            swingDir := endP > startP ? 1 : endP < startP ? -1 : 0
            if startP >= endP
                pivotHighBar := lastPvt.start.index
                pivotLowBar := lastPvt.end.index
            else
                pivotHighBar := lastPvt.end.index
                pivotLowBar := lastPvt.start.index
    [newPivot, pivotHighPrice, pivotLowPrice, pivotHighBar, pivotLowBar, swingDir]

[zzNewPivot, zzHighPrice, zzLowPrice, zzHighBar, zzLowBar, zzSwingDir] = fibZzUpdate()

var float fibAnchorHigh = na
var float fibAnchorLow = na
var int anchorHighBar = na
var int anchorLowBar = na
var int lastBreakBar = na

if zzNewPivot
    fibAnchorHigh := zzHighPrice
    fibAnchorLow := zzLowPrice
    anchorHighBar := zzHighBar
    anchorLowBar := zzLowBar
    lastBreakBar := na

float fibRange = fibAnchorHigh - fibAnchorLow
float minFibRange = minFibRangeAtr * atr14
bool isValid = not na(fibAnchorHigh) and not na(fibAnchorLow) and fibRange >= minFibRange

float fibMidpoint = fibAnchorLow + fibRange * 0.5
float fibHystBand = fibRange * (fibHysteresisPct * 0.01)

var bool fibBull = true
if isValid
    if close >= fibMidpoint + fibHystBand
        fibBull := true
    else if close <= fibMidpoint - fibHystBand
        fibBull := false
else
    fibBull := true

float fibBase = fibBull ? fibAnchorLow : fibAnchorHigh
float fibDir = fibBull ? 1.0 : -1.0
fibPrice(float ratio) =>
    fibRange <= 0 ? na : fibBase + fibDir * fibRange * ratio

float pZero = fibPrice(FIB_ZERO)
float pNeg236 = fibPrice(-FIB_236)
float p236 = fibPrice(FIB_236)
float p382 = fibPrice(FIB_382)
float pPivot = fibPrice(FIB_PIVOT)
float p618 = fibPrice(FIB_618)
float p786 = fibPrice(FIB_786)
float pOne = fibPrice(FIB_ONE)
float pT1 = fibPrice(FIB_T1)
float p1382 = fibPrice(FIB_W1382)
float p150 = fibPrice(FIB_W150)
float pT2 = fibPrice(FIB_T2)
float pT3 = fibPrice(FIB_T3)
float pT4 = fibPrice(FIB_T4)

float zoneUpper = math.max(p618, p786)
float zoneLower = math.min(p618, p786)
float zoneFillUpper = math.max(p382, p618)
float zoneFillLower = math.min(p382, p618)

float htfFibDir = fibBull ? 1.0 : -1.0
float htf1hP382 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_382, htfFibDir)
float htf1hP500 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_PIVOT, htfFibDir)
float htf1hP618 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_618, htfFibDir)

float htfRangeForConfluence = fibRange
int htfConfPivot = htfConfluenceCheck(pPivot, htf1hP500, htfRangeForConfluence)
int htfConf382 = htfConfluenceCheck(p382, htf1hP382, htfRangeForConfluence)
int htfConf618 = htfConfluenceCheck(p618, htf1hP618, htfRangeForConfluence)
int htfConfTotal = htfConfPivot + htfConf382 + htfConf618

//=====================
// Structure conditions
//=====================
bool confirmed = barstate.isconfirmed
int dir = fibBull ? 1 : -1
bool zoneReady = not na(zoneUpper) and not na(zoneLower) and not na(pPivot)
bool breakInDir = zoneReady and confirmed ? (dir == 1 ? close > zoneUpper and close[1] <= zoneUpper : close < zoneLower and close[1] >= zoneLower) : false
if breakInDir
    lastBreakBar := bar_index
int barsSinceBreak = na(lastBreakBar) ? int(na) : bar_index - lastBreakBar

bool rsiStanceBull = finalRsi <= rsiOversold
bool rsiStanceBear = finalRsi >= rsiOverbought

//=====================
// Trade state (declared early so trigger logic and trade engine share state cleanly)
//=====================
var bool tradeActive = false
var int tradeSide = 0
var float tradeEntryPrice = na
var float tradeStopPrice = na
var float tradeTargetPrice = na
// Freeze the full TP ladder at entry so active-trade fibs remain true to the
// entry fib geometry even if the hidden structural fib recalculates mid-trade.
var float tradeTp1Price = na  // 1.000
var float tradeTp2Price = na  // 1.236
var float tradeTp3Price = na  // 1.618
var float tradeTp4Price = na  // 2.000
var float tradeTp5Price = na  // 2.236
var int tradeDrawLeftBar = na
var int tradeEntryBar = na
var int tradeClosedCount = 0
var int tradeWinCount = 0
var int tradeLossCount = 0
var int tradeTimeExitCount = 0
// Outcome codes: 0=none, 1=target, -1=stop, 2=time
var int tradeLastExitOutcome = 0
var float tradeTotalWinPoints = 0.0
var float tradeTotalLossPoints = 0.0

//=====================
// Qualified signal — pullback retest of {0.500, 0.618, 0.786} + structural gates
// Long: bull context, price pulls back DOWN to touch level
// Short: bear context, price pulls back UP to touch level
//=====================
float level500 = fibPrice(FIB_PIVOT)
float level618 = fibPrice(FIB_618)
float level786 = fibPrice(FIB_786)

bool touched500Long = confirmed and dir == 1 and not na(level500) and close[1] > level500 and low <= level500 and close >= level500
bool touched618Long = confirmed and dir == 1 and not na(level618) and close[1] > level618 and low <= level618 and close >= level618
bool touched786Long = confirmed and dir == 1 and not na(level786) and close[1] > level786 and low <= level786 and close >= level786
bool triggerLong = touched500Long or touched618Long or touched786Long

bool touched500Short = confirmed and dir == -1 and not na(level500) and close[1] < level500 and high >= level500 and close <= level500
bool touched618Short = confirmed and dir == -1 and not na(level618) and close[1] < level618 and high >= level618 and close <= level618
bool touched786Short = confirmed and dir == -1 and not na(level786) and close[1] < level786 and high >= level786 and close <= level786
bool triggerShort = touched500Short or touched618Short or touched786Short

float entryLevel = touched786Long ? level786 : touched618Long ? level618 : touched500Long ? level500 : touched786Short ? level786 : touched618Short ? level618 : touched500Short ? level500 : na

bool maLongOk = maBull
bool maShortOk = maBear

// 6E up = EUR strong vs USD = USD weakening = long-favorable.
// 6E down = USD strengthening = short-favorable.
int xaLongAgreement = (nqCode > 0 ? 1 : 0) + (eurUsdCode > 0 ? 1 : 0)
int xaShortAgreement = (nqCode < 0 ? 1 : 0) + (eurUsdCode < 0 ? 1 : 0)
bool xaLongOk = not useXaGate or xaLongAgreement >= xaMinAgreement
bool xaShortOk = not useXaGate or xaShortAgreement >= xaMinAgreement
bool recentLiqBull = not useLiqGate or (not na(barsSinceLiqBull) and barsSinceLiqBull < liqRecencyBars)
bool recentLiqBear = not useLiqGate or (not na(barsSinceLiqBear) and barsSinceLiqBear < liqRecencyBars)

bool qualifiedLong = confirmed and isValid and triggerLong and maLongOk and xaLongOk and recentLiqBull
bool qualifiedShort = confirmed and isValid and triggerShort and maShortOk and xaShortOk and recentLiqBear

//=====================
// Trade engine — single source of truth for entry events
//=====================
float longStopCandidate = not na(entryLevel) ? entryLevel - atr14 * tradeStopAtrMult : na
float shortStopCandidate = not na(entryLevel) ? entryLevel + atr14 * tradeStopAtrMult : na
// Target = selected fib-extension ratio applied via the protected fibPrice()
// helper. fibPrice handles direction (long picks the extension above, short
// picks the mirrored extension below) and returns na if fib_range invalid.
float longTargetCandidate = fibPrice(tradeTpRatio)
float shortTargetCandidate = fibPrice(tradeTpRatio)

bool tradeActivePrev = tradeActive
if not tradeActive
    if qualifiedLong and not na(entryLevel) and not na(longStopCandidate) and not na(longTargetCandidate)
        tradeActive := true
        tradeSide := 1
        tradeEntryPrice := entryLevel
        tradeStopPrice := longStopCandidate
        tradeTargetPrice := longTargetCandidate
        tradeTp1Price := pOne
        tradeTp2Price := pT1
        tradeTp3Price := pT2
        tradeTp4Price := pT3
        tradeTp5Price := pT4
        int entryFallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
        bool entryAnchorBarsReady = not na(anchorHighBar) and not na(anchorLowBar)
        int entryAnchorStartBar = entryAnchorBarsReady ? int(math.max(0, math.min(anchorHighBar, anchorLowBar))) : entryFallbackLeftBar
        int entryDrawLeftBarBase = useConfluenceAnchorSpan ? entryAnchorStartBar : entryFallbackLeftBar
        tradeDrawLeftBar := int(math.max(entryDrawLeftBarBase, entryAnchorStartBar))
        tradeEntryBar := bar_index
    else if qualifiedShort and not na(entryLevel) and not na(shortStopCandidate) and not na(shortTargetCandidate)
        tradeActive := true
        tradeSide := -1
        tradeEntryPrice := entryLevel
        tradeStopPrice := shortStopCandidate
        tradeTargetPrice := shortTargetCandidate
        tradeTp1Price := pOne
        tradeTp2Price := pT1
        tradeTp3Price := pT2
        tradeTp4Price := pT3
        tradeTp5Price := pT4
        int entryFallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
        bool entryAnchorBarsReady = not na(anchorHighBar) and not na(anchorLowBar)
        int entryAnchorStartBar = entryAnchorBarsReady ? int(math.max(0, math.min(anchorHighBar, anchorLowBar))) : entryFallbackLeftBar
        int entryDrawLeftBarBase = useConfluenceAnchorSpan ? entryAnchorStartBar : entryFallbackLeftBar
        tradeDrawLeftBar := int(math.max(entryDrawLeftBarBase, entryAnchorStartBar))
        tradeEntryBar := bar_index

if tradeActive and not na(tradeEntryBar) and bar_index > tradeEntryBar
    bool stopHit = false
    bool targetHit = false
    bool timeOut = tradeMaxHoldBars > 0 and (bar_index - tradeEntryBar) >= tradeMaxHoldBars
    if tradeSide == 1
        stopHit := not na(tradeStopPrice) and low <= tradeStopPrice
        targetHit := not na(tradeTargetPrice) and high >= tradeTargetPrice
    else if tradeSide == -1
        stopHit := not na(tradeStopPrice) and high >= tradeStopPrice
        targetHit := not na(tradeTargetPrice) and low <= tradeTargetPrice
    if stopHit or targetHit or timeOut
        tradeClosedCount += 1
        if stopHit
            tradeLossCount += 1
            tradeTotalLossPoints += math.abs(tradeStopPrice - tradeEntryPrice)
            tradeLastExitOutcome := -1
        else if targetHit
            tradeWinCount += 1
            tradeTotalWinPoints += math.abs(tradeTargetPrice - tradeEntryPrice)
            tradeLastExitOutcome := 1
        else
            tradeTimeExitCount += 1
            float timePnl = tradeSide == 1 ? close - tradeEntryPrice : tradeEntryPrice - close
            if timePnl >= 0
                tradeTotalWinPoints += timePnl
            else
                tradeTotalLossPoints += math.abs(timePnl)
            tradeLastExitOutcome := 2
        tradeActive := false
        tradeSide := 0
        tradeEntryPrice := na
        tradeStopPrice := na
        tradeTargetPrice := na
        tradeTp1Price := na
        tradeTp2Price := na
        tradeTp3Price := na
        tradeTp4Price := na
        tradeTp5Price := na
        tradeDrawLeftBar := na
        tradeEntryBar := na

int tradeBarsActive = tradeActive and not na(tradeEntryBar) ? bar_index - tradeEntryBar : 0

// Single-source-of-truth entry events: rising edge of tradeActive on bar of new trade
bool entryLongTrigger = tradeActive and not tradeActivePrev and tradeSide == 1
bool entryShortTrigger = tradeActive and not tradeActivePrev and tradeSide == -1

//=====================
// Draw fib ladder + trade lifecycle visibility flip
//=====================
fibLabelSize = f_label_size(fibLabelSizeInput)

// Fib lines (kept levels: 0, -.236, .236, .382, .500, .618, .786, 1.0, 1.236, 1.382, 1.5, 1.618, 2.0, 2.236)
var line lineZero = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineNeg236 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line236 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line382 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePivot = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line618 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line786 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineOne = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT1 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line1382 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line150 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT2 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT3 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT4 = line.new(bar_index, close, bar_index, close, color=color(na), width=2)

// Trade lifecycle lines (reuse SAME plumbing/widths/colors as fibs)
var line lineEntry = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineSL    = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineTP    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineTP1   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineTP2   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineTP3   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineTP4   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineTP5   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)

var box zoneBox = box.new(bar_index, close, bar_index, close, bgcolor=color(na), border_color=color(na))

var label _fibLblZero = na
var label _fibLblNeg236 = na
var label _fibLbl236 = na
var label _fibLbl382 = na
var label _fibLblPivot = na
var label _fibLbl618 = na
var label _fibLbl786 = na
var label _fibLblOne = na
var label _fibLblT1 = na
var label _fibLbl1382 = na
var label _fibLbl150 = na
var label _fibLblT2 = na
var label _fibLblT3 = na
var label _fibLblT4 = na
var label _entryLbl = na
var label _slLbl = na
var label _tpLbl = na
var label _tp1Lbl = na
var label _tp2Lbl = na
var label _tp3Lbl = na
var label _tp4Lbl = na
var label _tp5Lbl = na

int fallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
bool anchorBarsReady = not na(anchorHighBar) and not na(anchorLowBar)
int anchorStartBar = anchorBarsReady ? int(math.max(0, math.min(anchorHighBar, anchorLowBar))) : fallbackLeftBar
int drawLeftBarBase = useConfluenceAnchorSpan ? anchorStartBar : fallbackLeftBar
int drawLeftBar = int(math.max(drawLeftBarBase, anchorStartBar))

drawAnchoredLine(line id, bool visible, float price, color col, int width_, int leftBar, string styleName) =>
    if visible and not na(price)
        int clampedLeftBar = int(math.max(leftBar, 0))
        int rightBar = extendLevelsRight ? bar_index + fibLabelOffsetBarsInput : bar_index
        line.set_xy1(id, clampedLeftBar, price)
        line.set_xy2(id, rightBar, price)
        line.set_color(id, col)
        line.set_width(id, width_)
        line.set_style(id, f_line_style(styleName))
        line.set_extend(id, extend.none)
    else
        line.set_color(id, color(na))

setFibLevelLabel(label idIn, bool visible, float price, string txt, color col) =>
    label id = idIn
    if visible and not na(price)
        int labelX = bar_index + fibLabelOffsetBarsInput
        string labelText = txt + "  " + str.tostring(price, format.mintick)
        if na(id)
            id := label.new(labelX, price, labelText, style=label.style_label_left, color=fibLabelBgColorInput, textcolor=fibLabelFontColorInput, size=fibLabelSize)
        label.set_xy(id, labelX, price)
        label.set_text(id, labelText)
        label.set_color(id, fibLabelBgColorInput)
        label.set_textcolor(id, fibLabelFontColorInput)
        label.set_size(id, fibLabelSize)
    else if not na(id)
        label.delete(id)
        id := na
    id

bool fibsVisible = not tradeActive and isValid

drawAnchoredLine(lineZero, fibsVisible, pZero, fibAnchorColorInput, fibAnchorWidthInput, drawLeftBar, fibAnchorStyle)
drawAnchoredLine(lineNeg236, false, pNeg236, fibStopColorInput, fibStopWidthInput, drawLeftBar, fibStopStyle)
drawAnchoredLine(line236, fibsVisible, p236, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar, fibRetraceStyle)
drawAnchoredLine(line382, fibsVisible, p382, fibRetracementAccentColorInput, fibRetracementAccentWidthInput, drawLeftBar, fibAccentStyle)
drawAnchoredLine(linePivot, fibsVisible, pPivot, fib500ColorInput, fib500WidthInput, drawLeftBar, fib500Style)
drawAnchoredLine(line618, fibsVisible, p618, fib618ColorInput, fib618WidthInput, drawLeftBar, fib618Style)
drawAnchoredLine(line786, fibsVisible, p786, fib786ColorInput, fib786WidthInput, drawLeftBar, fib786Style)
drawAnchoredLine(lineOne, fibsVisible, pOne, fibOneColorInput, fibOneWidthInput, drawLeftBar, fibOneStyle)
drawAnchoredLine(lineT1, fibsVisible, pT1, fibTargetColorInput, fibTargetWidthInput, drawLeftBar, fibTargetStyle)
drawAnchoredLine(line1382, fibsVisible, p1382, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar, fibRetraceStyle)
drawAnchoredLine(line150, fibsVisible, p150, fibRetracementColorInput, fibRetracementWidthInput, drawLeftBar, fibRetraceStyle)
drawAnchoredLine(lineT2, fibsVisible, pT2, fibTargetColorInput, fibTargetWidthInput, drawLeftBar, fibTargetStyle)
drawAnchoredLine(lineT3, fibsVisible, pT3, fibTargetColorInput, fibTargetWidthInput, drawLeftBar, fibTargetStyle)
drawAnchoredLine(lineT4, fibsVisible, pT4, fibTargetColorInput, fibTargetWidthInput, drawLeftBar, fibTargetStyle)

int tradeLineLeftBar = tradeActive and not na(tradeDrawLeftBar) ? tradeDrawLeftBar : drawLeftBar
drawAnchoredLine(lineEntry, tradeActive, tradeEntryPrice, fibAnchorColorInput, fibAnchorWidthInput, tradeLineLeftBar, fibAnchorStyle)
drawAnchoredLine(lineSL, tradeActive, tradeStopPrice, fibStopColorInput, fibStopWidthInput, tradeLineLeftBar, fibStopStyle)
drawAnchoredLine(lineTP, tradeActive, tradeTargetPrice, fibTargetColorInput, fibTargetWidthInput, tradeLineLeftBar, fibTargetStyle)
drawAnchoredLine(lineTP1, tradeActive, tradeTp1Price, fibTargetColorInput, fibRetracementWidthInput, tradeLineLeftBar, fibTargetStyle)
drawAnchoredLine(lineTP2, tradeActive, tradeTp2Price, fibTargetColorInput, fibRetracementWidthInput, tradeLineLeftBar, fibTargetStyle)
drawAnchoredLine(lineTP3, tradeActive, tradeTp3Price, fibTargetColorInput, fibRetracementWidthInput, tradeLineLeftBar, fibTargetStyle)
drawAnchoredLine(lineTP4, tradeActive, tradeTp4Price, fibTargetColorInput, fibRetracementWidthInput, tradeLineLeftBar, fibTargetStyle)
drawAnchoredLine(lineTP5, tradeActive, tradeTp5Price, fibTargetColorInput, fibRetracementWidthInput, tradeLineLeftBar, fibTargetStyle)

if fibsVisible and not na(zoneFillUpper) and not na(zoneFillLower)
    box.set_left(zoneBox, drawLeftBar)
    box.set_right(zoneBox, bar_index)
    box.set_top(zoneBox, zoneFillUpper)
    box.set_bottom(zoneBox, zoneFillLower)
    box.set_bgcolor(zoneBox, color.new(fibPivotColorInput, zoneFillTransparencyInput))
    box.set_border_color(zoneBox, color.new(fibPivotColorInput, 100))
else
    box.set_bgcolor(zoneBox, color(na))
    box.set_border_color(zoneBox, color(na))

if barstate.islast
    _fibLblZero := setFibLevelLabel(_fibLblZero, showFibLevelLabelsInput and fibsVisible, pZero, "0", fibAnchorColorInput)
    _fibLblNeg236 := setFibLevelLabel(_fibLblNeg236, false, pNeg236, "-.236", fibStopColorInput)
    _fibLbl236 := setFibLevelLabel(_fibLbl236, showFibLevelLabelsInput and fibsVisible, p236, ".236", fibRetracementColorInput)
    _fibLbl382 := setFibLevelLabel(_fibLbl382, showFibLevelLabelsInput and fibsVisible, p382, ".382", fibRetracementAccentColorInput)
    _fibLblPivot := setFibLevelLabel(_fibLblPivot, showFibLevelLabelsInput and fibsVisible, pPivot, ".500", fib500ColorInput)
    _fibLbl618 := setFibLevelLabel(_fibLbl618, showFibLevelLabelsInput and fibsVisible, p618, ".618", fib618ColorInput)
    _fibLbl786 := setFibLevelLabel(_fibLbl786, showFibLevelLabelsInput and fibsVisible, p786, ".786", fib786ColorInput)
    _fibLblOne := setFibLevelLabel(_fibLblOne, showFibLevelLabelsInput and fibsVisible, pOne, "1.000", fibOneColorInput)
    _fibLblT1 := setFibLevelLabel(_fibLblT1, showFibLevelLabelsInput and fibsVisible, pT1, "T1", fibTargetColorInput)
    _fibLbl1382 := setFibLevelLabel(_fibLbl1382, showFibLevelLabelsInput and fibsVisible, p1382, "1.382", fibRetracementColorInput)
    _fibLbl150 := setFibLevelLabel(_fibLbl150, showFibLevelLabelsInput and fibsVisible, p150, "1.500", fibRetracementColorInput)
    _fibLblT2 := setFibLevelLabel(_fibLblT2, showFibLevelLabelsInput and fibsVisible, pT2, "T2", fibTargetColorInput)
    _fibLblT3 := setFibLevelLabel(_fibLblT3, showFibLevelLabelsInput and fibsVisible, pT3, "T3", fibTargetColorInput)
    _fibLblT4 := setFibLevelLabel(_fibLblT4, showFibLevelLabelsInput and fibsVisible, pT4, "T4", fibTargetColorInput)
    string _slLblText = "SL@" + str.tostring(tradeStopAtrMult, "#.#") + "x" + (slMultMode == "Auto" ? " (Auto)" : "")
    string _tpLblText = "TP@" + str.tostring(tradeTpRatio, "#.###") + (tpRatioMode == "Auto" ? " (Auto)" : "")
    _entryLbl := setFibLevelLabel(_entryLbl, tradeActive, tradeEntryPrice, "ENTRY",   fibAnchorColorInput)
    _slLbl    := setFibLevelLabel(_slLbl,    tradeActive, tradeStopPrice,  _slLblText, fibStopColorInput)
    _tpLbl    := setFibLevelLabel(_tpLbl,    tradeActive, tradeTargetPrice,_tpLblText, fibTargetColorInput)
    _tp1Lbl   := setFibLevelLabel(_tp1Lbl,   tradeActive, tradeTp1Price,   "TP1 1.000", fibTargetColorInput)
    _tp2Lbl   := setFibLevelLabel(_tp2Lbl,   tradeActive, tradeTp2Price,   "TP2 1.236", fibTargetColorInput)
    _tp3Lbl   := setFibLevelLabel(_tp3Lbl,   tradeActive, tradeTp3Price,   "TP3 1.618", fibTargetColorInput)
    _tp4Lbl   := setFibLevelLabel(_tp4Lbl,   tradeActive, tradeTp4Price,   "TP4 2.000", fibTargetColorInput)
    _tp5Lbl   := setFibLevelLabel(_tp5Lbl,   tradeActive, tradeTp5Price,   "TP5 2.236", fibTargetColorInput)

//=====================
// Status table — black bg, white body, dark gray dividers; headers unchanged
//=====================
color TBL_BG_BODY    = #000000
color TBL_BG_HEADER  = #FFFFFF
color TBL_TEXT_BODY  = #FFFFFF
color TBL_TEXT_HDR   = #000000
color TBL_BORDER     = #333333

//=====================
// D/W level horizontal lines (PDH/PDL/PWH/PWL)
//=====================
var line linePdh = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePdl = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePwh = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePwl = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var label lblPdh = na
var label lblPdl = na
var label lblPwh = na
var label lblPwl = na

f_set_level_line(line ln, bool show, float price, color col, int leftBar) =>
    if show and not na(price)
        line.set_xy1(ln, leftBar, price)
        line.set_xy2(ln, bar_index + fibLabelOffsetBarsInput, price)
        line.set_color(ln, col)
        line.set_width(ln, 1)
        line.set_style(ln, line.style_dotted)
    else
        line.set_color(ln, color(na))

f_set_level_label(label idIn, bool show, float price, string txt, color col) =>
    label id = idIn
    if show and not na(price)
        int x = bar_index + fibLabelOffsetBarsInput
        if na(id)
            id := label.new(x, price, txt, style=label.style_label_left, color=color.new(color.black, 70), textcolor=col, size=size.tiny)
        label.set_xy(id, x, price)
        label.set_text(id, txt)
        label.set_textcolor(id, col)
    else if not na(id)
        label.delete(id)
        id := na
    id

int lvlLeftBar = int(math.max(0, bar_index - 200))
f_set_level_line(linePdh, showPdh, pdh, lvlDayColor, lvlLeftBar)
f_set_level_line(linePdl, showPdl, pdl, lvlDayColor, lvlLeftBar)
f_set_level_line(linePwh, showPwh, pwh, lvlWeekColor, lvlLeftBar)
f_set_level_line(linePwl, showPwl, pwl, lvlWeekColor, lvlLeftBar)
if barstate.islast
    lblPdh := f_set_level_label(lblPdh, showPdh, pdh, "PDH", lvlDayColor)
    lblPdl := f_set_level_label(lblPdl, showPdl, pdl, "PDL", lvlDayColor)
    lblPwh := f_set_level_label(lblPwh, showPwh, pwh, "PWH", lvlWeekColor)
    lblPwl := f_set_level_label(lblPwl, showPwl, pwl, "PWL", lvlWeekColor)

string positionText = tradeActive ? (tradeSide == 1 ? "LONG" : "SHORT") : "WAITING"
string entryPriceText = tradeActive ? str.tostring(tradeEntryPrice, format.mintick) : "--"
string tpSlText = tradeActive ? "TP@" + str.tostring(tradeTpRatio, "#.###") + (tpRatioMode == "Auto" ? "(A)" : "") + " " + str.tostring(tradeTargetPrice, format.mintick) + " / SL@" + str.tostring(tradeStopAtrMult, "#.#") + "x" + (slMultMode == "Auto" ? "(A)" : "") + " " + str.tostring(tradeStopPrice, format.mintick) : "-- / --"
string barsInTradeText = tradeActive ? str.tostring(tradeBarsActive) : "--"

float winRatePct = tradeClosedCount > 0 ? float(tradeWinCount) / float(tradeClosedCount) * 100.0 : na
float profitFactor = tradeTotalLossPoints > 0 ? tradeTotalWinPoints / tradeTotalLossPoints : na
string winRateText = na(winRatePct) ? "--" : str.tostring(winRatePct, "#.##") + "%"
string totalTradesText = str.tostring(tradeClosedCount)
string winLossText = str.tostring(tradeWinCount) + " / " + str.tostring(tradeLossCount)
string profitFactorText = na(profitFactor) ? "--" : str.tostring(profitFactor, "#.##")

// Per-TF trend labels (same 5-grade f_xa_label scheme as cross-asset)
string trend5Text = f_xa_label(tfTrend5Code)
string trend15Text = f_xa_label(tfTrend15Code)
string trend60Text = f_xa_label(tfTrend60Code)
string trend240Text = f_xa_label(tfTrend240Code)

// XA rollup — single bull/bear summary across NQ + 6E votes.
// xaLongAgreement and xaShortAgreement are each 0..2. Net is -2..+2.
// Mapped to the 5-grade f_xa_label scale (2 = unanimous, 1 = single vote).
int xaNet = xaLongAgreement - xaShortAgreement
string xaText = xaNet >= 2 ? "VERY BULLISH" : xaNet >= 1 ? "BULLISH" : xaNet <= -2 ? "VERY BEARISH" : xaNet <= -1 ? "BEARISH" : "NEUTRAL"

// XA Corr — how many of the 2 cross-assets push in the dominant direction.
// When NEUTRAL (net=0), shows the larger side (a 1/1 split renders "1 / 2").
int xaCorrCount = xaNet > 0 ? xaLongAgreement : xaNet < 0 ? xaShortAgreement : math.max(xaLongAgreement, xaShortAgreement)
string xaCorrText = str.tostring(xaCorrCount) + " / 2"

// Volume Pressure rollup — uses footprint aggressor pulse (delta z-score)
// when footprint is enabled, otherwise falls back to signed volume z-score
// (sign = bar direction). Same 5-grade label scheme as XA.
float volPressureRaw = useFootprint ? fpAggressorPulse : (bullishCandle ? volZscore : bearishCandle ? -volZscore : 0.0)
string volPressureText = volPressureRaw >= 2.0 ? "VERY BULLISH" : volPressureRaw >= 0.5 ? "BULLISH" : volPressureRaw <= -2.0 ? "VERY BEARISH" : volPressureRaw <= -0.5 ? "BEARISH" : "NEUTRAL"

f_cell_h(table t, int c, int r, string txt) =>
    table.cell(t, c, r, txt, text_color=TBL_TEXT_HDR, bgcolor=color.new(TBL_BG_HEADER, 0), text_size=f_label_size(tableTextSizeInput))

f_cell_b(table t, int c, int r, string txt) =>
    table.cell(t, c, r, txt, text_color=TBL_TEXT_BODY, bgcolor=color.new(TBL_BG_BODY, 0), text_size=f_label_size(tableTextSizeInput))

var table mlTable = na
if barstate.isfirst and showMlTable
    mlTable := table.new(f_table_pos(tablePositionInput), 2, 19, bgcolor=color.new(TBL_BG_BODY, 0), border_color=color.new(TBL_BORDER, 0), border_width=1, frame_color=color.new(TBL_BORDER, 0), frame_width=1, force_overlay=true)

if showMlTable and not na(mlTable) and barstate.islast
    // TREND — chart symbol on 5m/15m/1h/4h (same 5-grade scale as XA)
    f_cell_h(mlTable, 0, 0, "TREND")
    f_cell_h(mlTable, 1, 0, "")
    f_cell_b(mlTable, 0, 1, "5M")
    f_cell_b(mlTable, 1, 1, trend5Text)
    f_cell_b(mlTable, 0, 2, "15M")
    f_cell_b(mlTable, 1, 2, trend15Text)
    f_cell_b(mlTable, 0, 3, "1H")
    f_cell_b(mlTable, 1, 3, trend60Text)
    f_cell_b(mlTable, 0, 4, "4H")
    f_cell_b(mlTable, 1, 4, trend240Text)
    // TRADES — live position state
    f_cell_h(mlTable, 0, 5, "TRADES")
    f_cell_h(mlTable, 1, 5, "")
    f_cell_b(mlTable, 0, 6, "POSITION")
    f_cell_b(mlTable, 1, 6, positionText)
    f_cell_b(mlTable, 0, 7, "ENTRY PRICE")
    f_cell_b(mlTable, 1, 7, entryPriceText)
    f_cell_b(mlTable, 0, 8, "TP / SL")
    f_cell_b(mlTable, 1, 8, tpSlText)
    f_cell_b(mlTable, 0, 9, "BARS IN TRADE")
    f_cell_b(mlTable, 1, 9, barsInTradeText)
    // STATISTICS — cumulative closed-trade counters
    f_cell_h(mlTable, 0, 10, "STATISTICS")
    f_cell_h(mlTable, 1, 10, "")
    f_cell_b(mlTable, 0, 11, "WIN RATE")
    f_cell_b(mlTable, 1, 11, winRateText)
    f_cell_b(mlTable, 0, 12, "TOTAL TRADES")
    f_cell_b(mlTable, 1, 12, totalTradesText)
    f_cell_b(mlTable, 0, 13, "WINS / LOSSES")
    f_cell_b(mlTable, 1, 13, winLossText)
    f_cell_b(mlTable, 0, 14, "PROFIT FACTOR")
    f_cell_b(mlTable, 1, 14, profitFactorText)
    // ANALYTICS — rolled-up signals only (NQ + 6E → XA, footprint → Volume Pressure)
    f_cell_h(mlTable, 0, 15, "ANALYTICS")
    f_cell_h(mlTable, 1, 15, "")
    f_cell_b(mlTable, 0, 16, "XA")
    f_cell_b(mlTable, 1, 16, xaText)
    f_cell_b(mlTable, 0, 17, "XA CORR")
    f_cell_b(mlTable, 1, 17, xaCorrText)
    f_cell_b(mlTable, 0, 18, "VOLUME PRESSURE")
    f_cell_b(mlTable, 1, 18, volPressureText)

//=====================
// Alerts
//=====================
alertcondition(entryLongTrigger, title="Warbird Pro V9 - Long Entry", message="Warbird Pro V9 LONG entry on {{ticker}} {{interval}} @ {{close}}")
alertcondition(entryShortTrigger, title="Warbird Pro V9 - Short Entry", message="Warbird Pro V9 SHORT entry on {{ticker}} {{interval}} @ {{close}}")

//=====================
// Optuna export fields (not chart visuals)
//=====================
// structural / regime
plot(atr14, "ml_atr14", display=display.none, editable=false)
plot(float(dir), "ml_dir", display=display.none, editable=false)
plot(fibRange, "ml_fib_range", display=display.none, editable=false)
plot(atr14 > 0 ? (close - pPivot) / atr14 : 0.0, "ml_pivot_dist_atr", display=display.none, editable=false)
plot(atr14 > 0 ? (close - p618) / atr14 : 0.0, "ml_p618_dist_atr", display=display.none, editable=false)
plot(na(barsSinceBreak) ? -1.0 : float(barsSinceBreak), "ml_bars_since_break", display=display.none, editable=false)
plot(breakInDir ? 1.0 : 0.0, "ml_break_in_dir", display=display.none, editable=false)

// momentum
plot(finalRsi, "ml_rsi_value", display=display.none, editable=false)
plot(rsiStanceBull ? 1.0 : rsiStanceBear ? -1.0 : 0.0, "ml_rsi_stance_code", display=display.none, editable=false)
plot(maBull ? 1.0 : maBear ? -1.0 : 0.0, "ml_ma_bias", display=display.none, editable=false)
plot(atr14 > 0 and not na(smoothingMA) ? (close - smoothingMA) / atr14 : 0.0, "ml_ma_slow_dist_atr", display=display.none, editable=false)
plot(atr14 > 0 ? (close - out) / atr14 : 0.0, "ml_ma_fast_dist_atr", display=display.none, editable=false)

// ADX
plot(adxValue, "ml_adx_value", display=display.none, editable=false)
plot(adxDiPlus, "ml_adx_plus_di", display=display.none, editable=false)
plot(adxDiMinus, "ml_adx_minus_di", display=display.none, editable=false)

// liquidity primitives (BSL/SSL sweep/reclaim)
plot(atr14 > 0 ? (bsl - close) / atr14 : 0.0, "ml_bsl_dist_atr", display=display.none, editable=false)
plot(atr14 > 0 ? (close - ssl) / atr14 : 0.0, "ml_ssl_dist_atr", display=display.none, editable=false)
plot(sweptBslBar ? 1.0 : 0.0, "ml_swept_bsl", display=display.none, editable=false)
plot(sweptSslBar ? 1.0 : 0.0, "ml_swept_ssl", display=display.none, editable=false)
plot(reclaimedBsl ? 1.0 : 0.0, "ml_reclaimed_bsl", display=display.none, editable=false)
plot(reclaimedSsl ? 1.0 : 0.0, "ml_reclaimed_ssl", display=display.none, editable=false)

// liquidity expansions (equal H/L pools, VWAP, volume z-score)
plot(eqhDistAtr, "ml_liq_eqh_dist_atr", display=display.none, editable=false)
plot(eqlDistAtr, "ml_liq_eql_dist_atr", display=display.none, editable=false)
plot(vwapDistAtr, "ml_liq_vwap_dist_atr", display=display.none, editable=false)
plot(volZscore, "ml_liq_vol_zscore", display=display.none, editable=false)

// cross-asset (configured timeframe; ZN and VIX removed 2026-05-13)
plot(float(nqCode), "ml_xa_nq_code", display=display.none, editable=false)
plot(float(eurUsdCode), "ml_xa_6e_code", display=display.none, editable=false)

// cross-asset advanced (ES↔NQ correlation; DXY divergence removed 2026-05-11)
plot(corrMesNq, "ml_xa_corr_nq", display=display.none, editable=false)

// HTF confluence
plot(float(htfConfTotal), "ml_htf_conf_total", display=display.none, editable=false)

// daily context (confirmed daily close uses D close[1] to avoid intraday repaint)
plot(dailyOpen, "ml_daily_open", display=display.none, editable=false)
plot(dailyCloseConfirmed, "ml_daily_close", display=display.none, editable=false)

// footprint (real intrabar bid/ask delta, POC, VA position)
plot(fpDeltaPct, "ml_fp_delta_pct", display=display.none, editable=false)
plot(fpPocDistAtr, "ml_fp_poc_dist_atr", display=display.none, editable=false)
plot(float(fpVaPosition), "ml_fp_va_position", display=display.none, editable=false)
plot(fpDeltaAcceleration, "ml_delta_acceleration", display=display.none, editable=false)
plot(fpAggressorPulse, "ml_aggressor_pulse", display=display.none, editable=false)
plot(fpAbsorptionCandidate ? 1.0 : 0.0, "ml_absorption_candidate", display=display.none, editable=false)
plot(fpFlushCandidate ? 1.0 : 0.0, "ml_flush_candidate", display=display.none, editable=false)
plot(fpVolumeSpikeRatio, "ml_volume_spike_ratio", display=display.none, editable=false)
plot(fpPocShift, "ml_poc_shift", display=display.none, editable=false)

// triggers + trade engine
plot(entryLongTrigger ? 1.0 : 0.0, "ml_entry_long_trigger", display=display.none, editable=false)
plot(entryShortTrigger ? 1.0 : 0.0, "ml_entry_short_trigger", display=display.none, editable=false)
plot(tradeEntryPrice, "ml_trade_entry", display=display.none, editable=false)
plot(tradeStopPrice, "ml_trade_stop", display=display.none, editable=false)
// Fib-ladder TPs (always emitted from current fib geometry; not live-trade-only).
// Replaces the single `ml_trade_tp` plot 2026-05-12. The trainer reads these
// five columns directly to size each (sl_mult, tp_ratio) combo's TP price
// without reconstruction via _tp_price_from_ratio. Fib levels 1.000 / 1.236 /
// 1.618 / 2.000 / 2.236 map to DISCOVERABLE_TP_RATIOS in
// scripts/ag/train_v9_locked.py.
plot(pOne, "ml_trade_tp1", display=display.none, editable=false)
plot(pT1,  "ml_trade_tp2", display=display.none, editable=false)
plot(pT2,  "ml_trade_tp3", display=display.none, editable=false)
plot(pT3,  "ml_trade_tp4", display=display.none, editable=false)
plot(pT4,  "ml_trade_tp5", display=display.none, editable=false)
plot(float(tradeLastExitOutcome), "ml_last_exit_outcome", display=display.none, editable=false)
